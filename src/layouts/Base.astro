---
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

/** 사이드바 하단에 펼칠 문서 목차 한 줄 */
export interface TocItem {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  /** 사이드바를 접은 채로 시작할지 */
  sidebarCollapsed?: boolean;
  /**
   * 현재 페이지가 프로젝트 상세일 때, 사이드바에서 그 프로젝트를 현재 위치로 표시한다.
   * projects.yaml 의 키.
   */
  activeProject?: string;
  /** 현재 문서의 목차. 활성 프로젝트 아래에 펼쳐진다. */
  toc?: TocItem[];
}

const {
  title,
  description,
  sidebarCollapsed = false,
  activeProject,
  toc = [],
} = Astro.props;

/** GitHub Pages base 대응. 로컬(base 미설정)=''  ·  배포='/Portfolio_Pipeline'. 끝 슬래시는 벗겨 통일. */
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />

    {/* 본문 Pretendard, 코드·라벨 JetBrains Mono — 가이드가 권하는 2폰트 구성 */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <div class="shell">
      <Sidebar collapsed={sidebarCollapsed} activeProject={activeProject} toc={toc} />
      <main class="main">
        <slot />
      </main>
    </div>

    {/* 다이어그램·이미지 확대 — 클릭하면 전체화면으로 크게 본다. 확대 전용 소량 스크립트다. */}
    <div id="zoom" hidden><div id="zoom-inner"></div></div>
    <script is:inline>
      (function () {
        const overlay = document.getElementById('zoom');
        const inner = document.getElementById('zoom-inner');
        if (!overlay || !inner) return;
        const open = (node) => { inner.replaceChildren(node); overlay.hidden = false; document.documentElement.style.overflow = 'hidden'; };
        const close = () => { overlay.hidden = true; inner.replaceChildren(); document.documentElement.style.overflow = ''; };
        overlay.addEventListener('click', close);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
        document.addEventListener('click', (e) => {
          const dia = e.target.closest('.dia-body');
          if (dia) {
            const svg = dia.querySelector('svg');
            if (svg) {
              const c = svg.cloneNode(true);
              c.removeAttribute('width'); c.removeAttribute('height');
              c.style.width = 'min(94vw, 1500px)'; c.style.height = 'auto';
              open(c);
            }
            return;
          }
          const img = e.target.closest('#doc figure img');
          if (img) {
            const c = document.createElement('img');
            c.src = img.getAttribute('src'); c.alt = img.getAttribute('alt') || '';
            open(c);
          }
        });
      })();
    </script>
  </body>
</html>

<style>
  /*
   * 사이드바가 자기 width로 폭을 정하고(Sidebar.astro의 flex: none),
   * 본문이 남은 자리를 채운다. 접힘 상태를 이 컴포넌트가 알 필요가 없다.
   */
  .shell {
    display: flex;
    min-height: 100dvh;
  }
  .main {
    flex: 1;
    min-width: 0;
    padding: 60px 54px 96px;
  }

  @media (max-width: 860px) {
    .shell { flex-direction: column; }
    .main { padding: 30px 20px 48px; }
  }
</style>

<style is:global>
  /* 다이어그램·이미지 확대 오버레이 (#1 돋보기) */
  #zoom { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 24px; background: rgba(23, 24, 26, .93); cursor: zoom-out; overflow: auto; }
  #zoom[hidden] { display: none; }
  #zoom-inner svg, #zoom-inner img { background: #fff; border-radius: 10px; padding: 16px; box-sizing: border-box; box-shadow: 0 24px 70px rgba(0, 0, 0, .45); }
  #zoom-inner img { max-width: 94vw; max-height: 90vh; width: auto; height: auto; }
  #zoom-inner svg { max-height: 90vh; }
  /* 확대 가능 힌트 */
  #doc .dia-body, #doc figure img { cursor: zoom-in; }
</style>
