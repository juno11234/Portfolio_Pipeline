{
    if (context.runtimeSkill != null && context.runtimeSkill.Data != null)
    {
        string skillId = context.runtimeSkill.Data.Id;
        if (_config.TryGetSceneId(skillId, out string sceneId))
        {
            string[] sprites = CollectTargetSpriteAddresses(context, allEnemies);
            await _cutSceneLoader.Load(sceneId, sprites);   // 컷씬 먼저
        }
    }
    if (original != null)
        await original.Invoke(context);                    // 원본 타격 로직
};
character.onBattleAction = wrapper;      // += 가 아닌 대입 — 체인 교체
_wrapperDelegates[character] = wrapper;  // 이중 래핑 방지 추적`;

