  { title: 'PerRendererData 배칭', body: '머티리얼 공유로 드로우콜 절약, 스프라이트별 텍스처는 렌더러가 주입' },
  { title: '런타임 파라미터 제어', body: '`PropertyToID` 정적 캐싱 + `unscaledTime` 연동으로 timeScale 0에서도 작동' },
];

const timelineFeatures = [
  { title: '비파괴 오버라이드', body: '원본 값을 캐싱했다가 `OnPlayableDestroy`에서 복원' },
  { title: '이중 가중치 블렌딩', body: '타임라인 크로스페이드 × 클립 내부 fadeIn/Out을 가중 합성' },
  { title: '에디터 스크럽 안전', body: '그래프 재빌드로 플래그가 어긋나도 **머티리얼 참조 비교**로 안전 복구' },
];

/* ── 07 회고 ─────────────────────────────────────────────── */
const contrastPast = {
  label: '과거 팀 프로젝트',
  items: ['클래스 간 결합도가 높아 **실행 순서에 의존**', '싱글톤 남용으로 의존 관계 추적 곤란', 'Script Execution Order로 순서 강제'],
};
const contrastNow = {
  label: '현재 팀 프로젝트',
  items: ['**VContainer**로 씬 생명주기 관리', '외부 주입으로 초기화 순서 제어', '==인터페이스를 참조==하는 구조'],
};

const scopeInsight = {
  title: 'VContainer 스코프 상속 — 직접 실험으로 검증하고 md로 팀에 공유',
  items: [
    { label: 'Singleton', body: '자식에서 접근해도 **부모와 같은 인스턴스**' },
    { label: 'Scoped', body: '자식마다 **부모와 다른 인스턴스**' },
    { label: '재등록', body: 'Singleton이라도 자식이 새로 등록하면 **다른 인스턴스**' },
  ],
  footer: '**알게된 점** — 계기는 자식 Scope에서 부모의 `TurnManager` 접근 시 오작동이었습니다. Lifetime은 **씬 수명이 아니라 요청을 처리하는 컨테이너 구역** 기준임을 실험으로 확인했습니다.',
};

const retroCards = [
  {
    title: 'CI / CD 도입 지연',
    body: '“게임이 한 바퀴는 돌아야 빌드 테스트가 가능하다”는 판단으로 미뤄졌고, 결국 제일 마지막에 붙여 자동화의 이점을 살리지 못했습니다.',
    lesson: '**배운 점** — 코어 루프 완성 직후 **빌드 파이프라인부터** 세운다.',
  },
  {
    title: '버티컬 슬라이스 과대',
    body: '모든 스테이지 유형(일반·엘리트·이벤트·캠프·보스) 1회 클리어를 기준으로 삼아 진행이 더뎌졌고, 일반 전투 하나로 좁힌 뒤에야 방향이 구체화됐습니다.',
    lesson: '**배운 점** — 슬라이스는 **최소 핵심 코어 루프** 기준으로 자른다.',
  },
];
---

<Base
  title="Bond — 로그라이크 턴제 RPG (조립본)"
  description="절차적 노드 맵을 탐사하는 Slay the Spire식 로그라이크 RPG. 4인 팀에서 맵 생성·씬 흐름·전투·연출을 담당했습니다."
  activeProject="bond"
  toc={toc}
>
  <div id="doc" style="margin-left:0;padding:0">
    <div style="max-width:860px;margin:0 auto;padding:0">

      <SectionHead num="01" title="개요" id="sec-1" first>
        <Pills items={['4인 팀 프로젝트', '담당 · 21 모듈 101 스크립트', 'Unity · C# · Rider', '로그라이크 턴제 RPG']} />
        <Figure
          src="/design/bond-gameplay.png"
          alt="Bond 인게임 전투 화면"
          kind="hero"
          background="#12160f"
          label="SCREENSHOT"
          caption="파티 vs 몬스터 턴제 전투 — 상단 턴 순서 큐, 하단 선택 유닛 스탯·스킬·장비 패널"
          margin="0 0 24px"
        />
        <OverviewLede text="**절차적으로 생성되는 노드 맵**을 탐사하며 이벤트와 **파티 턴제 전투**를 진행하는 Slay the Spire식 로그라이크 RPG입니다. 저는 4인 팀에서 **맵 생성 · 씬 흐름 · 전투 루프 · 연출 시스템** 21개 모듈(101 스크립트)을 담당했습니다." />
        <GoalCards goals={goals} />
        <Tldr
          label="▶ 10초 요약 — 이 문서가 증명하는 것"
          body="**DI 3계층 + 목적별 정적 채널**로 씬 경계를 잇고, **단일 시드 결정론 맵 생성**·**다층 턴 루프**·**비파괴 Timeline 연출**을 인터페이스 기반으로 구현했습니다. AI를 **Plan·Build·Review** 에이전트로 나눠 정적 분석으로 결함 3건을 리뷰 단계에서 제거했습니다."
        />
        <PartTitle badge="기술 스택" title="데이터 주도 · 무할당을 위한 도구 선택" margin="0 0 4px" />
        <StackTable rows={stack} widths={[124, 172]} />
      </SectionHead>

      <ChapterDivider num="02" total="07" />

      <SectionHead num="02" title="시스템 구조" id="sec-2">
        <Lede
          margin="0 0 8px"
          kind="intro"
          text="씬 생명주기와 객체 수명을 일치시키기 위해 스코프를 **전역 · 원정 · 스테이지 3계층**으로 나눴습니다. 각 시스템은 ==인터페이스로만== 서로를 알고, 스코프가 넘지 못하는 씬 경계는 ==정적 채널==이 잇습니다."
        />

        <PartTitle badge="구성요소" title="DI 스코프 3계층 — 컨테이너 구역과 수명" margin="36px 0 6px" />
        <Layers layers={scopes} headTracking=".06em" />

        <PartTitle badge="관계" title="핵심 클래스 구조 · Class Diagram" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="맵 생성 · 효과 처리 · 턴 진행 **세 축 모두 인터페이스에 의존**하고, 구현체는 DI로 갈아끼웁니다 — 목표 ① ==구조 개선==의 실체입니다."
        />
        <ClassDiagram groups={diagramGroups} legend={legend} legendMargin={{ top: 22, pad: 16 }} />

        <PartTitle badge="흐름" title="씬 경계를 잇는 정적 채널 5종" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="`Addressables.LoadSceneAsync`는 씬에 파라미터를 넘길 수 없고 VContainer 스코프는 씬 경계를 못 넘습니다. 이 두 제약 때문에 **목적별 정적 채널**이 반복적으로 쓰입니다."
        />
        <ChannelTable headers={['채널', '자료구조', '방향']} rows={channels} margin="6px 0 8px" />
        <Callout
          badge="핵심"
          tone="tint"
          body="두 Completion 채널이 **Stack**인 이유는 상위 콜백(전투)을 유지한 채 다른 콜백(컷씬)을 최상위에 Push/Pop 하기 위해서입니다. `Invoke()`는 `Peek()`만 하고, 제거는 `Unregister()`의 책임입니다. 정적 상태 잔류는 `Clear()`로 방어합니다."
          padding="15px 17px"
          margin="18px 0 0"
        />
      </SectionHead>

      <ChapterDivider num="03" total="07" />

      <SectionHead num="03" title="AI 활용 개발" id="sec-3">
        <Lede
          margin="0 0 8px"
          kind="intro"
          text="AI를 개발 프로세스의 **단계별 전문 에이전트**로 분리하고 호출 규칙을 `.md` 파일로 명문화했습니다. 컨텍스트 오염을 방지하고 산출물의 일관성을 유지하는 것이 목적입니다."
        />

        <PartTitle badge="에이전트 구성" title="Plan · Build · Review 3 역할" margin="36px 0 6px" />
        <FlowCards cards={agents} arrow="→" margin="16px 0 4px" />

        <PartTitle badge="루프" title="스크립트가 아니라 계획 파일을 고친다" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="스크립트를 반복 생성·수정시키는 대신 **계획 md 한 파일**만 고칩니다. 원하는 결과까지의 ==토큰과 탐색 비용==이 줄어듭니다."
        />
        <LoopChips steps={loop} margin="14px 0" />

        <PartTitle badge="Reviewer" title="정적 분석이 리뷰 단계에서 잡은 결함 3건" margin="44px 0 6px" />
        <DefectList defects={defects} margin="16px 0 4px" />

        <PartTitle badge="역제안" title="완료 콜백 채널 — AI 제안을 내가 뒤집다" margin="44px 0 6px" />
        <Counter problem={counter.problem} counter={counter.reverse} result={counter.result} margin="16px 0" />
      </SectionHead>

      <ChapterDivider num="04" total="07" />

      <SectionHead num="04" title="절차적 맵 생성" id="sec-4">
        <FigureAside
          src="/design/bond-map.png"
          alt="절차 생성된 노드 맵"
          width={250}
          background="#8e8268"
          label="SCREENSHOT"
          caption="단일 시드 RNG를 전 단계가 공유하는 **결정론적 생성기** — 같은 시드는 항상 같은 맵을 만듭니다. 노드는 **버튼**, 엣지는 **Image의 회전·크기**로 그립니다(Canvas에서 LineRenderer 불가)."
          size="md"
          margin="8px 0 22px"
        />
        <PrincipleCards cards={mapFeatures} margin="6px 0 4px" />

        <PartTitle badge="파이프라인" title="GenerateMap — 10단계 동기 파이프라인" margin="44px 0 6px" />
        <StepGrid steps={genSteps} margin="16px 0" />
        <Lede
          margin="6px 0 0"
          kind="note"
          text="**시드 재현성의 핵심**은 `new System.Random(seed)` 인스턴스 하나를 열 단계 전체가 공유한다는 점입니다. 파라미터는 `MapGeneratorConfig`(TotalLayers 15 · EliteMinLayer 5 · MinCampingCount 2)로 외부화했습니다."
        />
        <WeightTable headers={['가중치 조건', 'Normal', 'Elite', 'Event', 'Camping']} rows={weightRows} margin="16px 0 4px" />

        <PartTitle badge="내비게이션" title="노드 상태 전이 — 한 방향 경로" margin="44px 0 6px" />
        <Lede
          margin="0 0 6px"
          lineHeight="1.64"
          text="선택하지 않은 형제 경로는 **영구 잠금**됩니다. Slay the Spire식 “한 방향 경로”를 `MoveToNode` 하나로 구현한 상태 머신입니다."
        />
        <StateChips steps={nodeStates} tail="형제 경로 → Locked 영구" />
        <Code source="MapNavigator.cs · MoveToNode()" code={moveToNodeCode} margin="16px 0" />

        <PartTitle badge="데이터" title="Config 로더 — Loader / Package / Cache 3단" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="Addressables 핸들을 해제하면 로드된 SO 참조도 무효화됩니다. 하지만 맵 생성 뒤에도 `StageConfig`를 계속 참조해야 하므로, **핸들 소유**와 **참조 보관**을 분리했습니다."
        />
        <FlowStrip stages={configStages} margin="14px 0" />

        <PartTitle badge="결정" title="씬 경계 데이터 전달 — 싱글톤 vs 정적 채널" margin="44px 0 6px" />
        <Decision options={sceneDecision.options} criteria={sceneDecision.criteria} reason={sceneDecision.reason} />
      </SectionHead>

      <ChapterDivider num="05" total="07" />

      <SectionHead num="05" title="전투" id="sec-5">
        <Lede
          margin="0 0 8px"
          kind="intro"
          text="진입 → 턴 루프 → 스킬 실행 → 종료의 **단방향 흐름**입니다. 연출은 이벤트로 분리되어 전투 로직을 막지 않고, `TurnManager`는 `ITurnUseUnit` 계약에만 의존합니다."
        />

        <PartTitle badge="턴 시스템" title="속도 내림차순 큐를 소진하는 다층 루프" margin="36px 0 6px" />
        <TurnFlow
          entries={[{ name: 'SwitchBattle', sub: '토글' }, { name: 'StartBattleAsync' }]}
          loopLabel="전투 루프 — while(_isBattleActive) · 라운드 간 1초 딜레이"
          loopHead="PlayRoundAsync — 1 라운드"
          steps={turnSteps}
          exit="BattleEnd — CTS 취소 전파"
          margin="16px 0"
        />
        <NoteCards cards={turnFeatures} columns={3} gap={12} cardPad="14px 15px" bodyFont="12px" bodyLh="1.55" margin="16px 0 4px" />
        <Callout
          badge="주의"
          tone="white"
          body="`SwitchBattle`은 **토글**입니다 — `m_cts != null`이면 두 번째 발화가 곧 전투 종료(`BattleEnd`)입니다. 하나의 진입점으로 시작과 종료를 겸합니다."
          padding="14px 16px"
          margin="14px 0 0"
        />

        <PartTitle badge="스킬" title="데이터 · 관리 · 실행의 분리" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="시트(TSV)로 밸런싱하는 데이터 주도 설계입니다. `SkillManager`는 생성 시 **3중 캐시**를 미리 구성해 조회를 할당 없이 O(1)로 끝냅니다."
        />
        <MiniCards cards={skillCaches} margin="14px 0" />
        <Lede
          margin="6px 0 0"
          kind="note"
          text="**ID 8자리 구조** `[시트][타입][순번][예약]`로 타입을 자릿수에 인코딩합니다. 쿨타임은 `Dictionary<BaseCharacter, Dictionary<string,int>>` 이중 딕셔너리로 관리하며, 순회 중 수정을 피하려 `_keyBuffer`에 키를 복사한 뒤 감쇄합니다."
        />
        <Callout
          badge="Rule"
          tone="tint"
          body="**Blind Logic** — 스킬은 **상태 변화만** 처리하고(`_effectManager.ApplyEffects`), 비주얼 연출과 타격 적용은 `onBattleAction` 델리게이트에 위임합니다. 덕분에 다음 장의 컷씬을 ==전투 코드 수정 없이== 끼워 넣을 수 있습니다."
          padding="15px 17px"
          margin="16px 0 0"
        />
      </SectionHead>

      <ChapterDivider num="06" total="07" />

      <SectionHead num="06" title="연출 · 이펙트" id="sec-6">
        <PartTitle badge="스킬 컷씬" title="전투 코드를 건드리지 않는 델리게이트 미들웨어" margin="8px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="원본 `onBattleAction`을 **클로저로 캡처**한 뒤 컷씬 래퍼로 덮어씌웁니다. 시간을 멈추고, 컷씬을 Additive로 띄우고, 완료 신호로 `await`을 푼 뒤 원본을 호출합니다."
        />
        <Code source="SkillCutSceneInjector.cs · 래퍼 주입" code={injectorCode} margin="14px 0" />
        <ApiList groups={timeScaleDevices} sigWidth={210} firstHeadPadBottom={6} margin="14px 0 0" />

        <PartTitle badge="셰이더" title="속도선 · 실루엣 — URP 커스텀 셰이더" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="**텍스처 없이** GPU에서 선을 생성하는 속도선과, `SpriteRenderer.color`로는 불가능한 **원본↔단색 연속 보간** 실루엣을 ShaderLab · HLSL로 구현했습니다."
        />
        <FigureGrid
          margin="14px 0 4px"
          cells={[
            {
              src: '/design/bond-speedline.png',
              alt: '속도선 셰이더 인게임',
              background: '#0f0f10',
              explicit: { width: 376, height: 191 },
              caption: '**속도선** — 텍스처 없이 GPU 생성 · 치명타 강조',
            },
            {
              src: '/design/bond-silhouette.png',
              alt: '실루엣 셰이더 인게임',
              background: '#fff',
              caption: '**실루엣** — 원본↔단색 연속 보간',
            },
          ]}
        />
        <NoteCards cards={shaderFeatures} columns={3} gap={10} cardPad="13px 14px" bodyFont="11.5px" bodyLh="1.5" margin="14px 0 4px" />

        <PartTitle badge="Timeline" title="Playables 커스텀 트랙 — 4계층" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          lineHeight="1.64"
          text="카메라 셰이크 · 실루엣 트랙을 **Track · Clip · Behaviour · Mixer** 구조로 구현했습니다. 트랙은 씬 상태를 ==비파괴적으로 오버라이드==합니다."
        />
        <FlowChips steps={['TrackAsset', 'Clip (PlayableAsset)', 'ClipBehaviour', 'MixerBehaviour']} margin="14px 0" />
        <NoteCards cards={timelineFeatures} columns={3} gap={10} cardPad="13px 14px" bodyFont="11.5px" bodyLh="1.5" margin="14px 0 4px" />
      </SectionHead>

      <ChapterDivider num="07" total="07" />

      <SectionHead num="07" title="회고" id="sec-7">
        <PartTitle badge="잘한 점" title="과거 vs 현재 — 구조가 바뀐 지점" margin="8px 0 6px" />
        <ContrastBox past={contrastPast} now={contrastNow} margin="16px 0" />
        <InsightBox title={scopeInsight.title} items={scopeInsight.items} footer={scopeInsight.footer} margin="14px 0" />

        <PartTitle badge="아쉬운 점" title="다음엔 순서를 바꾼다" margin="44px 0 6px" />
