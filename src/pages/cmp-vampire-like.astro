  { item: 'JobType.Mage', state: 'GetSkillList가 Warrior만 필터링 · 진입 경로 없음' },
  { item: 'EnemyStat.attackType', state: 'EnemyController가 분기에 미사용 (현재 모두 근접)' },
  { item: 'GetSkillList() 캐시', state: '호출자가 수정 시 오염 가능 (다음 Clear로 무해하나 위험)' },
  { item: 'Max_Event_Count', state: '큐 길이 제한 상수만 선언, 사용처 없음' },
];

const plan = [
  '**직업 확장** — `PlayerWarriorId` 하드코딩을 제거하고 직업 선택 경로 + GetSkillList 필터 파라미터화',
  '**스킬 아이콘 매핑 데이터화** — `SkillSelectButton`의 switch 하드코딩을 데이터로 이동',
  '**StatLevelUp 연결** — 정의만 된 스탯 레벨업 시스템을 런타임 조회·반영까지 완성',
];
---

<Base
  title="뱀서라이크 — 탑뷰 핵 앤 슬래시 (조립본)"
  description="수백 마리의 적을 자동 공격으로 처치하는 뱀서라이크 장르. GC 최적화에 초점을 맞췄습니다."
  activeProject="vampire-like"
  toc={toc}
>
  <div id="doc" style="margin-left:0;padding:0">
    <div style="max-width:860px;margin:0 auto;padding:0">

      <SectionHead num="01" title="개요" id="sec-1" first>
        <Pills items={['1인 개발', '2026.03.03–03.18 · 2주', 'Unity 6000.0.56f1', 'C# · Rider']} />
        <Figure
          src="/design/gameplay.png"
          alt="VamSirLike 인게임 플레이 화면"
          kind="hero"
          background="#1a120b"
          label="SCREENSHOT"
          caption="인게임 플레이 — 화면을 가득 채운 적, 자동 발동 스킬, 경험치 바(Lv.8)"
          margin="0 0 24px"
        />
        <WhatWhy
          what="수백 마리의 적을 **자동 공격**으로 처치하고, 경험치를 모아 레벨업하며 스킬 3종 중 하나를 선택·강화하는 **2D 탑다운 뱀서라이크**. 플레이어는 이동만 조작합니다."
          why="대량 오브젝트를 안정적으로 처리하기 위한 **GC 최적화**가 핵심 목표. 프레임을 멈추게 하는 GC 스파이크를 구조적으로 제거하는 것이 이 프로젝트의 승부처입니다."
        />
        <Tldr
          label="▶ 10초 요약 — 이 문서가 증명하는 것"
          body="**이벤트 큐 + 오브젝트 풀 + 무할당 물리 쿼리**로 프레임당 GC 할당을 **196회 → 4회(97%↓)**, Material 접근을 **824회 → 249회(70%↓)**로 줄여, 화면을 가득 채운 적 앞에서도 스파이크 없는 프레임을 확보했습니다."
        />
        <PartTitle badge="기술 스택" title="데이터 주도 · 무할당을 위한 도구 선택" margin="0 0 4px" />
        <StackTable rows={stack} widths={[118, 180]} />
      </SectionHead>

      <ChapterDivider num="02" total="05" />

      <SectionHead num="02" title="전체 시스템 구조" id="sec-2">
        <PartTitle badge="구성요소" title="조립 루트 → 매니저 → 런타임 객체의 4계층" margin="36px 0 6px" />
        <Layers layers={layers} headTracking=".08em" />

        <PartTitle badge="관계" title="핵심 클래스 구조 · Class Diagram" margin="44px 0 6px" />
        <Lede
          margin="0 0 14px"
          text="핵심 클래스의 **상속·구현·참조** 관계입니다. 플레이어와 적은 ==IFighter==를, 4종의 스킬은 ==SkillBase==를 공유하며, 전투 판정은 모두 ==CombatSystem==을 거칩니다."
        />
        <ClassDiagram groups={diagramGroups} relations={relations} legend={legend} legendMargin={{ top: 18, pad: 14 }} />

        <PartTitle badge="흐름" title="초기화 시퀀스 — 의존 순서를 await로 직렬화" margin="44px 0 6px" />
        <Lede
          margin="0 0 18px"
          text="**GameInitializer**(IAsyncStartable)가 실질적 진입점입니다. 데이터 로드가 끝나야 플레이어 스탯을 세팅할 수 있으므로, **await**로 순서를 강제해 “데이터 로드 전 플레이어 생성” 같은 경쟁 조건을 원천 차단합니다."
        />
        <Timeline steps={initSteps} />

        <PartTitle badge="설계 원칙" title="반복되는 세 가지 패턴" margin="44px 0 6px" />
        <PrincipleCards cards={principles} margin="16px 0 4px" />
      </SectionHead>

      <ChapterDivider num="03" total="05" />

      <SectionHead num="03" title="핵심 기능" id="sec-3">
        <PartTitle badge="핵심 동작" title="이벤트 큐 기반 전투" margin="36px 0 6px" />
        <Lede
          margin="0 0 6px"
          text="모든 데미지는 `InGameEvent` 구조체로 큐에 쌓이고, `CombatSystem.Tick()`이 한 프레임에 몰아서 처리합니다."
        />
        <EventFlow
          caption="이벤트 생산자 · PRODUCERS"
          producers={['CircleAttack', 'ProjectileAttack', 'BoomerangProjectile', 'SpiralProjectile', 'EnemyController']}
          produceLabel="AddInGameEvent()"
          queue="Queue<InGameEvent> _eventQueue"
          consumeLabel="VContainer ITickable · 매 프레임"
          consumer="CombatSystem.Tick() · switch(e.Type)"
          branches={[
            { name: 'Combat', body: 'Receiver.TakeDamage(e)' },
            { name: 'Heal', body: 'Receiver.Heal(e)' },
          ]}
          footer={{ label: '→ 수신자 ·', targets: ['PlayerController', 'EnemyController'] }}
        />
        <Code source="CombatSystem.cs · Tick()" code={tickCode} margin="16px 0" />

        <PartTitle badge="데이터" title="데이터 파이프라인 — TSV에서 런타임까지" margin="44px 0 6px" />
        <Pipeline stages={pipelineStages} margin="16px 0" />
        <Lede
          margin="0 0 4px"
          kind="note"
          text="저장은 직렬화에 유리한 **List**, 런타임 조회는 `id → 데이터`의 **O(1) Dictionary**로 재가공합니다. Importer는 탭 파싱·헤더 2줄 skip·칸 수 검증 후 `SetDirty`로 반영합니다."
        />
        <FigureAside
          src="/design/data-importer.png"
          alt="TSV Importer 에디터 윈도우"
          width={330}
          background="#2b2b2b"
          label="EDITOR TOOL"
          caption="**VamSir Tools ▸ Data Importer** — 대상 컨테이너(SO)와 4종 TSV를 인스펙터로 물려 버튼 한 번에 임포트하는 자체 제작 에디터 윈도우입니다."
          size="sm"
          margin="18px 0 4px"
        />

        <PartTitle badge="스킬" title="SkillBase 4종과 레벨업 계산" margin="44px 0 6px" />
        <DataTable headers={['스킬', '타격 방식', '대상', '레벨업']} rows={skillRows} margin="14px 0" />
        <Code source="SkillBase.cs · LevelUp()" code={levelUpCode} margin="16px 0" />

        <PartTitle badge="경험치" title="레벨업 곡선" margin="44px 0 6px" />
        <FormulaTable
          formula="RequiredExp = baseRequiredExp × level × 1.5"
          note="한 번에 큰 경험치를 얻으면 `while` 루프로 연속 레벨업이 발생합니다."
          headers={['레벨', '필요 경험치']}
          rows={expRows}
          margin="14px 0"
        />

        <PartTitle badge="적 생명주기" title="풀 재사용 상태 전이" margin="44px 0 6px" />
        <StateChips steps={lifecycle} />
        <Lede
          margin="0 0 4px"
          kind="note"
          text="**등록/해제는 풀의 createFunc / actionOnDestroy에만 걸려 있습니다.** 죽어서 Release될 때는 딕셔너리에서 빠지지 않으므로 재사용마다 재등록이 필요 없습니다. 사망 시 `경험치 스폰 + Release`가 콜백으로 묶여 실행됩니다."
        />

        <PartTitle badge="사용법 (API)" title="무엇을 호출하면 무엇이 나오는가" margin="44px 0 6px" />
        <ApiList groups={apiGroups} sigWidth={230} firstHeadPadBottom={4} margin="14px 0" />

        <Callout
          badge="CI"
          tone="white"
          title="빌드 자동화 · GitHub Actions"
          body="main 브랜치 병합 시 `build.yml`이 클라우드에서 Android APK를 자동 빌드합니다. GameCI 액션 + Secrets 암호화로 로컬 환경 편차와 라이선스 하드코딩을 제거했습니다."
          padding="15px 17px"
          margin="18px 0 0"
        />
      </SectionHead>

      <ChapterDivider num="04" total="05" />

      <SectionHead num="04" title="고민과 선택" id="sec-4">
        <PartTitle badge="결정 1" title="전투 처리 — 직접 호출 vs 이벤트 큐" margin="34px 0 6px" />
        <Decision options={d1.options} criteria={d1.criteria} reason={d1.reason} />

        <PartTitle badge="결정 2" title="충돌 판정 — OnTriggerEnter2D vs Raycast & OverlapCircle" margin="40px 0 6px" />
        <Decision options={d2.options} criteria={d2.criteria} reason={d2.reason} />

        <PartTitle badge="그 밖의 결정" title="힙 할당을 없애기 위한 선택들" margin="40px 0 6px" />
        <NoteCards cards={otherDecisions} columns={2} gap={12} cardPad="14px 16px" bodyFont="12.5px" bodyLh="1.55" margin="16px 0 4px" />

        <Figure
          src="/design/shadergraph-flash.png"
          alt="피격 플래시 ShaderGraph"
          kind="body"
          background="#232323"
          label="SHADER GRAPH"
          caption="피격 플래시 — 원본 텍스처와 FlashColor를 **_Amount**로 Lerp. 이 값만 MaterialPropertyBlock으로 덮어써 공유 머티리얼을 유지"
          margin="22px 0 0"
        />
      </SectionHead>

      <ChapterDivider num="05" total="05" />

      <SectionHead num="05" title="결과 · 회고" id="sec-5">
        <PartTitle badge="결과" title="최적화 전후 · Profiler 실측" margin="34px 0 6px" />
        <MetricsTable headers={['지표', '최적화 전', '최적화 후', '개선']} rows={metrics} margin="14px 0 10px" />
        <ConditionPills
          items={['테스트: 스폰딜레이 0.1s · 체력 1000 고정', 'Unity Profiler', 'Profile Analyzer · Compare']}
          marginBottom="6px"
        />
        <Figure
          src="/design/profiler-compare.png"
          alt="Unity Profile Analyzer 비교 뷰"
          kind="body"
          background="#fff"
          label="PROFILE ANALYZER"
          caption="최적화 전/후 마커별 Diff — 코루틴(SpawnLoop·FireCoroutine) 프레임 비용이 음수(개선)로 표시"
          margin="18px 0 6px"
        />

        <PartTitle badge="적용" title="GC 최적화 6가지" margin="40px 0 6px" />
        <CheckCards cards={gc} margin="16px 0 4px" />

        <PartTitle badge="배운 점" title="Troubleshooting" margin="40px 0 6px" />
        <LessonCard title="① 평균이 아니라 스파이크를 제거하는 것" kind="tint" cells={lesson1} margin="14px 0" />
        <LessonCard title="② 텍스처 압축도 트레이드오프의 대상" kind="plain" cells={lesson2} margin="14px 0" />

        <BeforeAfter
          margin="18px 0 4px"
          before={{
            badge: 'BEFORE',
            title: 'ASTC 6×6 압축',
            result: { src: '/design/tex-compressed-result.png', alt: '압축 후 뭉개진 픽셀아트' },
            settings: { src: '/design/tex-compressed-settings.png', alt: 'ASTC 압축 임포트 설정' },
            note: '색이 뭉개지고 픽셀 경계가 흐려짐',
          }}
          after={{
            badge: 'AFTER',
            title: 'RGBA 32bit 무압축',
            result: { src: '/design/tex-uncompressed-result.png', alt: '무압축 선명한 픽셀아트' },
            settings: { src: '/design/tex-uncompressed-settings.png', alt: 'RGBA 32bit 임포트 설정' },
            note: '선명한 픽셀 경계 복원 · 저해상도라 메모리 영향 미미',
          }}
        />

        <PartTitle badge="기술 부채" title="정의되어 있으나 런타임 미사용" margin="40px 0 6px" />
        <DebtTable headers={['항목', '상태']} rows={debt} firstWidth={240} margin="14px 0" />

        <PartTitle badge="개선 계획" title="다음 스텝" margin="40px 0 6px" />
        <PlanList items={plan} margin="14px 0 4px" />
      </SectionHead>

      <DocFooter thanks="감사합니다" thanksSub="THANK YOU" byline="이주노 · cozam2@naver.com · Unity · C#" />
    </div>
  </div>
</Base>
