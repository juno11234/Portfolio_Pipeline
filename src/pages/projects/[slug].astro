---
/**
 * 프로젝트 기술 문서 — YAML 콘텐츠를 **dc 컴포넌트로** 그린다.
 *
 * 이 파일이 파이프라인의 목적지다. `docs/{슬러그}.yaml` × dc 컴포넌트 → 정적 HTML.
 * 정적 페이지·cmp 페이지는 대조 기준이었고, YAML 이전이 끝나면 지운다.
 *
 * 구조(섹션·구분선·꼭지 제목)와 개요 조각은 dc 컴포넌트로, 본문 블록은 DocBlock 디스패처로 낸다.
 * 여백은 렌더러가 규칙으로 준다(섹션 첫 꼭지 vs 나머지 등) — 콘텐츠 파일은 CSS 를 들지 않는다.
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import type { TocItem } from '../../layouts/Base.astro';
import { rich } from '../../lib/rich';
import { cardsAreLong } from '../../lib/cardLayout';

import SectionHead from '../../components/dc/SectionHead.astro';
import ChapterDivider from '../../components/dc/ChapterDivider.astro';
import DocFooter from '../../components/dc/DocFooter.astro';
import PartTitle from '../../components/dc/PartTitle.astro';
import Pills from '../../components/dc/Pills.astro';
import Figure from '../../components/dc/Figure.astro';
import WhatWhy from '../../components/dc/WhatWhy.astro';
import OverviewLede from '../../components/dc/OverviewLede.astro';
import GoalCards from '../../components/dc/GoalCards.astro';
import Tldr from '../../components/dc/Tldr.astro';
import Decision from '../../components/dc/Decision.astro';
import StackTable from '../../components/dc/StackTable.astro';
import PrincipleCards from '../../components/dc/PrincipleCards.astro';
import LessonCard from '../../components/dc/LessonCard.astro';
import StackCards from '../../components/dc/StackCards.astro';
import DocBlock from '../../components/DocBlock.astro';

/** 기술 문서가 있는 프로젝트만 페이지를 만든다. 아직 문서 없는 프로젝트는 자동으로 빠진다. */
export const getStaticPaths: GetStaticPaths = async () => {
  const docs = await getCollection('projectDocs');
  return docs.map((doc) => ({ params: { slug: doc.id }, props: { doc } }));
};

const { doc } = Astro.props;
const d = doc.data;

const project = await getEntry('projects', doc.id);
if (project === undefined) {
  throw new Error(`projects.yaml 에 '${doc.id}' 항목이 없습니다. 기술 문서와 짝이 맞아야 합니다.`);
}
const profile = await getEntry('profile', 'profile');

/**
 * 화면 순서 = 가이드 Part 2의 5단. ③ 핵심 기능이 배열인 게 요점 — 규모가 크면 여러 그룹으로 쪼갠다.
 */
const groups = [d.architecture, ...d.features];
const hasStandalone = d.decisions.length > 0;

const num = (n: number): string => String(n).padStart(2, '0');
const totalSections = groups.length + 2 + (hasStandalone ? 1 : 0);
const decisionsNo = groups.length + 2;
const retroNo = groups.length + (hasStandalone ? 3 : 2);

const sections: TocItem[] = [
  { id: 'sec-overview', label: '개요' },
  ...groups.map((g, i) => ({ id: `sec-${i + 1}`, label: g.title })),
  ...(hasStandalone ? [{ id: 'sec-decisions', label: '고민과 선택' }] : []),
  { id: 'sec-retro', label: '결과 · 회고' },
];

/** 개요 위쪽 알약. 원본은 인원·기간·엔진·IDE·VCS 를 한 줄로. */
const pills: string[] = [d.meta.team, d.meta.period, d.meta.engine, d.meta.ide, d.meta.vcs];

const byline = `${profile?.data.name ?? '이주노'} · ${profile?.data.email ?? ''} · ${d.meta.engine.split(' ')[0]} · C#`;

/** 배지 없는 꼭지 제목의 여백 규칙 — 섹션 첫 꼭지는 위를 조금, 나머지는 넉넉히. */
const partMargin = (i: number): string => (i === 0 ? '36px 0 6px' : '44px 0 6px');
---

<Base
  title={`${project.data.title} — ${d.subtitle}`}
  description={d.overview.what ?? d.overview.lead ?? d.subtitle}
  sidebarCollapsed={false}
  activeProject={doc.id}
  toc={sections}
>
  <div id="doc">
    <header class="head">
      <div class="brand">
        <span class="bname">{project.data.title}</span>
        <span class="bbadge">PORTFOLIO</span>
      </div>
      <p class="bsub">{d.subtitle} · 기술 문서 · Technical Document</p>
    </header>

    {/* ① 개요 */}
    <SectionHead num="01" title="개요" id="sec-overview" first>
      <Pills items={pills} />
      <Figure
        src={d.screenshot.src.src}
        alt={d.screenshot.caption}
        kind="hero"
        background="#17181a"
        label="SCREENSHOT"
        caption={d.screenshot.caption}
        margin="0 0 24px"
      />
      {d.overview.lead !== undefined && <OverviewLede text={d.overview.lead} />}
      {d.overview.what !== undefined && d.overview.why !== undefined && (
        <WhatWhy what={d.overview.what} why={d.overview.why} />
      )}
      {d.overview.goals !== undefined && <GoalCards goals={d.overview.goals} />}
      <Tldr label="▶ 10초 요약 — 이 문서가 증명하는 것" body={d.overview.evidence} />
      {d.overview.scope !== undefined && (
        <div class="scopebox">
          <p class="scope-label">범위</p>
          <p class="scope-body" set:html={rich(d.overview.scope)} />
        </div>
      )}
      {d.links.length > 0 && (
        <ul class="links">
          {d.links.map((link) => (
            <li><a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}<span aria-hidden="true">↗</span></a></li>
          ))}
        </ul>
      )}
      {/* 기술 스택 — 개요 끝. 세 디자인 모두 섹션 01에 둔다(무엇으로 만들었나를 먼저 보인다). */}
      <PartTitle badge="기술 스택" title={d.overview.stack.title} margin="30px 0 6px" />
      <div class="stack-wrap"><StackTable rows={d.overview.stack.rows} widths={[118, 180]} /></div>
    </SectionHead>

    {/* ② 시스템 구조 + ③ 핵심 기능 */}
    {groups.map((section, si) => (
      <>
        <ChapterDivider num={num(si + 2)} total={num(totalSections)} />
        <SectionHead num={num(si + 2)} title={section.title} id={`sec-${si + 1}`}>
          {'intro' in section && section.intro !== undefined && (
            <p class="sec-intro" set:html={rich(section.intro)} />
          )}
          {section.parts.map((part, pi) => (
            <>
              {/* 제목 없는 꼭지(기능=섹션)는 제목 줄을 통째로 뺀다 — 섹션 헤더가 이미 제목이다. */}
              {(part.title !== undefined || part.badge !== undefined) && (
                part.badge !== undefined
                  ? <PartTitle badge={part.badge} title={part.title} margin={partMargin(pi)} />
                  : <h3 class="ph3" style={`margin:${partMargin(pi)}`}>{part.title}</h3>
              )}
              {part.lede !== undefined && <p class="plede" set:html={rich(part.lede)} />}
              {part.blocks.map((block) => <DocBlock block={block} />)}
            </>
          ))}
        </SectionHead>
      </>
    ))}

    {/* ④ 고민과 선택 — 한데 모을 때 */}
    {hasStandalone && (
      <>
        <ChapterDivider num={num(decisionsNo)} total={num(totalSections)} />
        <SectionHead num={num(decisionsNo)} title="고민과 선택" id="sec-decisions">
          <p class="plede" style="margin:34px 0 4px">"그냥"은 금지어입니다. 왜 다른 방법이 아닌 이 방법인지에 대한 근거입니다.</p>
          {d.decisions.map((dec, i) => (
            <>
              <PartTitle badge={`결정 ${i + 1}`} title={dec.title} margin="34px 0 6px" />
              <Decision options={dec.options} criteria={dec.criteria} reason={dec.reason} />
            </>
          ))}
        </SectionHead>
      </>
    )}

    {/* ⑤ 결과 · 회고 */}
    <ChapterDivider num={num(retroNo)} total={num(totalSections)} />
    <SectionHead num={num(retroNo)} title="결과 · 회고" id="sec-retro">
      {d.retrospective.results !== undefined && (
        <>
          <h3 class="ph3" style="margin:34px 0 6px">결과</h3>
          <ul class="results">{d.retrospective.results.map((r) => <li set:html={rich(r)} />)}</ul>
        </>
      )}
      {d.retrospective.satisfaction !== undefined && (
        <>
          <PartTitle badge="만족" title="만족스러운 부분" margin="36px 0 6px" />
          {/* 짧으면 3열 격자, 길면 전폭 세로 — 렌더러가 본문 길이로 정한다. */}
          {cardsAreLong(d.retrospective.satisfaction) ? (
            <StackCards margin="16px 0 4px" cards={d.retrospective.satisfaction.map((c) => ({ title: c.title, body: c.body ?? '' }))} />
          ) : (
            <PrincipleCards margin="16px 0 4px" cards={d.retrospective.satisfaction.map((c) => ({ title: c.title, body: c.body ?? '' }))} />
          )}
        </>
      )}
      <PartTitle badge="깨달음" title="아쉬웠던 점 · 깨달은 점" margin="40px 0 6px" />
      {/* cells 를 채운 깨달음은 디자인 원형인 전폭 세로 LessonCard. 아니면 본문 길이로 격자↔세로. */}
      {d.retrospective.learnings.every((l) => l.cells !== undefined) ? (
        d.retrospective.learnings.map((l) => (
          <LessonCard title={l.title} kind={l.tint === true ? 'tint' : 'plain'} cells={l.cells ?? []} margin="14px 0" />
        ))
      ) : cardsAreLong(d.retrospective.learnings) ? (
        <StackCards margin="16px 0 4px" cards={d.retrospective.learnings.map((l) => ({ title: l.title, body: l.body ?? '' }))} />
      ) : (
        <PrincipleCards margin="16px 0 4px" cards={d.retrospective.learnings.map((l) => ({ title: l.title, body: l.body ?? '' }))} />
      )}
      <PartTitle badge="개선" title="다음 계획" margin="40px 0 6px" />
      {cardsAreLong(d.retrospective.improvements) ? (
        <StackCards margin="16px 0 4px" cards={d.retrospective.improvements.map((c) => ({ title: c.title, body: c.body ?? '' }))} />
      ) : (
        <PrincipleCards margin="16px 0 4px" cards={d.retrospective.improvements.map((c) => ({ title: c.title, body: c.body ?? '' }))} />
      )}
    </SectionHead>

    <DocFooter thanks="감사합니다" thanksSub="THANK YOU" byline={byline} />
  </div>
</Base>

<style>
  #doc { max-width: var(--page-max); margin-inline: auto; }

  .head { padding-bottom: 30px; margin-bottom: 8px; border-bottom: 1px solid var(--line); }
  .brand { display: flex; align-items: center; gap: 9px; margin-bottom: 6px; }
  .bname { font-size: 30px; font-weight: 800; letter-spacing: -.03em; }
  .bbadge { font: 700 9px var(--mono); letter-spacing: .14em; color: #fff; background: var(--accent); border-radius: 4px; padding: 4px 7px; }
  .bsub { font: 500 11px var(--mono); letter-spacing: .06em; color: var(--ink-faint); }

  /* 배지 없는 꼭지 제목 — 디자인 PartTitle 의 제목 부분과 같은 크기 */
  .ph3 { font-size: 17px; font-weight: 800; letter-spacing: -.015em; color: var(--ink); }
  .plede { font-size: 13.5px; line-height: 1.66; color: var(--ink-soft); max-width: 660px; margin: 0 0 6px; }
  .sec-intro { font-size: 14px; line-height: 1.66; color: var(--ink-mid); max-width: 680px; margin: 0 0 8px; text-wrap: pretty; }

  .scopebox { display: grid; grid-template-columns: 52px 1fr; gap: 14px; padding: 0 2px; margin: 20px 0; }
  .scope-label { font: 600 9.5px var(--mono); letter-spacing: .12em; color: var(--ink-ghost); padding-top: 3px; }
  .scope-body { font-size: 13px; line-height: 1.7; color: var(--ink-faint); }

  .links { display: flex; gap: 7px; flex-wrap: wrap; }
  .links a { display: inline-flex; align-items: center; gap: 6px; background: var(--ink); color: #fff; font-size: 12.5px; font-weight: 700; padding: 8px 14px; border-radius: 999px; }
  .links a span { font: 400 11px var(--mono); color: #8fb4f8; }

  .stack-wrap { overflow-x: auto; margin: 4px 0 8px; }

  .results { display: grid; gap: 6px; margin: 14px 0; }
  .results li { font-size: 13.5px; line-height: 1.65; color: var(--ink-soft); padding-left: 15px; position: relative; }
  .results li::before { content: "✓"; position: absolute; left: 0; color: var(--good); font-weight: 800; font-size: 11px; }

  .debt-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; margin-top: 15px; }
  .debt-cols h4 { font: 600 9.5px var(--mono); letter-spacing: .14em; color: var(--ink-ghost); margin-bottom: 9px; }
  .debt, .plan { display: grid; gap: 7px; }
  .debt li, .plan li { font-size: 12.5px; line-height: 1.65; color: var(--ink-soft); padding-left: 16px; position: relative; }
  .debt li::before { content: "△"; position: absolute; left: 0; color: var(--warn); font-size: 10px; }
  .plan li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-size: 11px; }

  @media (max-width: 860px) {
    .bname { font-size: 24px; }
    .scopebox { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
