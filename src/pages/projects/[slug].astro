---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import type { TocItem } from '../../layouts/Base.astro';
import DocBlock from '../../components/DocBlock.astro';
import { rich } from '../../lib/rich';
import Decision from '../../components/Decision.astro';

/**
 * 기술 문서가 있는 프로젝트만 페이지를 만든다.
 * 아직 문서를 못 받은 프로젝트는 여기서 자동으로 빠진다.
 */
export const getStaticPaths: GetStaticPaths = async () => {
  const docs = await getCollection('projectDocs');
  return docs.map((doc) => ({ params: { slug: doc.id }, props: { doc } }));
};

const { doc } = Astro.props;
const d = doc.data;

const project = await getEntry('projects', doc.id);
if (project === undefined) {
  throw new Error(`projects.yaml 에 '${doc.id}' 항목이 없습니다. 기술 문서와 짝이 맞아야 합니다.`);
}

/**
 * 화면에 나올 섹션. 개요와 회고는 스키마가 강제하는 고정 섹션이고,
 * 가운데는 문서마다 다르다. 사이드바 목차도 이 배열에서 나온다.
 */
/**
 * 화면 순서 = 가이드 Part 2의 5단.
 *
 * ③ 핵심 기능이 배열인 것이 요점이다. 뱀서라이크는 '핵심 기능' 하나로 끝나지만
 * Bond는 규모가 커서 넷(AI 활용 개발 · 절차적 맵 생성 · 전투 · 연출·이펙트)으로 나뉜다.
 * 같은 단계를 프로젝트 크기에 따라 쪼갠 것이지 가운데가 자유로운 게 아니다.
 */
const groups = [d.architecture, ...d.features];

/** 결정을 한데 모아 보여주는 문서(뱀서라이크)만 독립 섹션을 갖는다 */
const hasStandalone = d.decisions.length > 0;

const sections: TocItem[] = [
  { id: 'sec-overview', label: '개요' },
  ...groups.map((g, i) => ({ id: `sec-${i + 1}`, label: g.title })),
  ...(hasStandalone ? [{ id: 'sec-decisions', label: '고민과 선택' }] : []),
  { id: 'sec-retro', label: '결과 · 회고' },
];

const decisionsNo = groups.length + 2;
const retroNo = groups.length + (hasStandalone ? 3 : 2);

const num = (n: number): string => String(n).padStart(2, '0');

/** 개요 위쪽 알약. 원본 디자인은 인원·기간·엔진·IDE를 한 줄로 늘어놓는다. */
const pills: string[] = [d.meta.team, d.meta.period, d.meta.engine, d.meta.ide, d.meta.vcs];
---

<Base
  title={`${project.data.title} — ${d.subtitle}`}
  description={d.overview.what}
  sidebarCollapsed={false}
  activeProject={doc.id}
  toc={sections}
>
  <div class="page">
    <header class="head">
      <div class="brand">
        <span class="bname">{project.data.title}</span>
        <span class="bbadge">PORTFOLIO</span>
      </div>
      <p class="bsub">{d.subtitle} · 기술 문서 · Technical Document</p>
    </header>

    {/* ① 개요 */}
    <section class="section" id="sec-overview" data-section>
      <div class="shead">
        <span class="snum">{num(1)}</span>
        <div>
          <p class="slabel">SECTION 01</p>
          <h2>개요</h2>
        </div>
      </div>

      <ul class="pills">
        {pills.map((p) => <li class="tnum">{p}</li>)}
      </ul>

      <figure class="shot">
        <Image
          src={d.screenshot.src}
          alt={d.screenshot.caption}
          widths={[760, 1520]}
          sizes="(max-width: 860px) 100vw, 760px"
        />
        <figcaption>
          <span class="shot-label">SCREENSHOT</span>
          {d.screenshot.caption}
        </figcaption>
      </figure>

      <div class="wcols">
        <div class="wcol">
          <p class="wlabel">WHAT</p>
          <p class="wbody" set:html={rich(d.overview.what)} />
        </div>
        <div class="wcol">
          <p class="wlabel">WHY</p>
          <p class="wbody" set:html={rich(d.overview.why)} />
        </div>
      </div>

      {/* 가이드: "결론부터 제시해 10초 안에 핵심이 잡혀야 합니다." */}
      <div class="tldr">
        <p class="tldr-label">▶ 10초 요약 — 측정된 문제</p>
        <p class="tldr-body" set:html={rich(d.overview.evidence)} />
      </div>

      <div class="scopebox">
        <p class="scope-label">범위</p>
        <p class="scope-body" set:html={rich(d.overview.scope)} />
      </div>

      {d.links.length > 0 && (
        <ul class="links">
          {d.links.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.label}<span aria-hidden="true">↗</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    {/* ② 시스템 구조 + ③ 핵심 기능 (프로젝트가 크면 여러 그룹) */}
    {groups.map((section, si) => (
      <section class="section" id={`sec-${si + 1}`} data-section>
        <div class="shead">
          <span class="snum">{num(si + 2)}</span>
          <div>
            <p class="slabel">SECTION {num(si + 2)}</p>
            <h2>{section.title}</h2>
          </div>
        </div>

        {section.parts.map((part) => (
          <article class="part">
            <h3>{part.title}</h3>
            {part.lede !== undefined && <p class="lede" set:html={rich(part.lede)} />}
            <div class="blocks">
              {part.blocks.map((block) => <DocBlock block={block} />)}
            </div>
          </article>
        ))}

        {/* 이 기능을 만들며 내린 판단은 그 기능 바로 뒤에 붙인다 (Bond 방식) */}
        {'decisions' in section && section.decisions.map((dec, i) => (
          <article class="part">
            <p class="dno">결정 {i + 1}</p>
            <Decision decision={dec} />
          </article>
        ))}
      </section>
    ))}

    {/* ④ 고민과 선택 — 한데 모아 보여줄 때만 (뱀서라이크 방식) */}
    {hasStandalone && (
    <section class="section" id="sec-decisions" data-section>
      <div class="shead">
        <span class="snum">{num(decisionsNo)}</span>
        <div>
          <p class="slabel">SECTION {num(decisionsNo)}</p>
          <h2>고민과 선택</h2>
        </div>
      </div>
      <p class="lede" style="margin-bottom:18px">
        "그냥"은 금지어입니다. 왜 다른 방법이 아닌 이 방법인지에 대한 근거입니다.
      </p>
      <div class="decisions">
        {d.decisions.map((dec, i) => (
          <article class="part">
            <p class="dno">결정 {i + 1}</p>
            <Decision decision={dec} />
          </article>
        ))}
      </div>
    </section>
    )}

    {/* ⑤ 결과 · 회고 */}
    <section class="section" id="sec-retro" data-section>
      <div class="shead">
        <span class="snum">{num(retroNo)}</span>
        <div>
          <p class="slabel">SECTION {num(retroNo)}</p>
          <h2>결과 · 회고</h2>
        </div>
      </div>

      <article class="part">
        <h3>결과</h3>
        <p class="lede">개요에서 세운 목표가 달성됐는지 측정값으로 확인합니다.</p>
        <ul class="results">
          {d.retrospective.results.map((r) => <li set:html={rich(r)} />)}
        </ul>
      </article>

      {d.retrospective.troubleshooting.map((t) => (
        <article class="part">
          <h3>{t.problem}</h3>
          <dl class="tshoot">
            <div><dt>원인</dt><dd set:html={rich(t.cause)} /></div>
            <div><dt>해결</dt><dd set:html={rich(t.fix)} /></div>
            <div class="is-lesson"><dt>알게된 점</dt><dd set:html={rich(t.lesson)} /></div>
          </dl>
        </article>
      ))}

      <article class="part">
        <h3>남은 기술 부채와 개선 계획</h3>
        <p class="lede">한계를 아는 것도 실력의 증거입니다.</p>
        <div class="debt-cols">
          <div>
            <h4>아쉬운 점</h4>
            <ul class="debt">{d.retrospective.debt.map((x) => <li set:html={rich(x)} />)}</ul>
          </div>
          <div>
            <h4>다음엔 이렇게</h4>
            <ul class="plan">{d.retrospective.plan.map((x) => <li set:html={rich(x)} />)}</ul>
          </div>
        </div>
      </article>
    </section>
  </div>
</Base>

<style>
  .page { max-width: var(--page-max); margin-inline: auto; }

  /* ---------- 문서 표지 ---------- */
  .head { padding-bottom: 30px; margin-bottom: 8px; border-bottom: 1px solid var(--line); }
  .brand { display: flex; align-items: center; gap: 9px; margin-bottom: 6px; }
  .bname { font-size: 30px; font-weight: 800; letter-spacing: -.03em; }
  .bbadge {
    font: 700 9px var(--mono);
    letter-spacing: .14em;
    color: #fff;
    background: var(--accent);
    border-radius: 4px;
    padding: 4px 7px;
  }
  .bsub { font: 500 11px var(--mono); letter-spacing: .06em; color: var(--ink-faint); }

  /* ---------- 섹션 헤더 ---------- */
  .section { scroll-margin-top: 24px; padding-top: 52px; }
  .shead { display: flex; align-items: flex-end; gap: 16px; margin-bottom: 22px; }
  .snum {
    font-size: 62px;
    font-weight: 800;
    line-height: .78;
    letter-spacing: -.045em;
    color: var(--ink);
    border-bottom: 5px solid var(--accent);
    padding-bottom: 5px;
    font-variant-numeric: tabular-nums;
  }
  .shead > div { padding-bottom: 6px; }
  .slabel {
    font: 600 11px var(--mono);
    letter-spacing: .16em;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .shead h2 { font-size: 30px; font-weight: 800; letter-spacing: -.025em; }

  .shot {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 22px;
  }
  .shot img { width: 100%; height: auto; display: block; }
  .shot figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 10px 14px 12px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-faint);
  }
  .shot-label {
    flex: none;
    font: 700 8.5px var(--mono);
    letter-spacing: .14em;
    color: #fff;
    background: var(--accent);
    border-radius: 4px;
    padding: 3px 6px;
  }

  /* ---------- 개요 ---------- */
  .pills { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 22px; }
  .pills li {
    font: 600 10.5px var(--mono);
    color: var(--accent-strong);
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    border-radius: 20px;
    padding: 5px 11px;
  }

  .wcols { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-bottom: 22px; }
  .wcol { border-left: 2px solid var(--accent-line); padding-left: 15px; }
  .wlabel { font: 600 10px var(--mono); letter-spacing: .16em; color: var(--accent); margin-bottom: 7px; }
  .wbody { font-size: 14px; line-height: 1.72; color: var(--ink-soft); text-wrap: pretty; }

  .tldr {
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    border-radius: var(--radius);
    padding: 20px 22px;
    margin-bottom: 14px;
  }
  .tldr-label { font: 600 10px var(--mono); letter-spacing: .14em; color: var(--accent); margin-bottom: 9px; }
  .tldr-body { font-size: 14.5px; line-height: 1.68; color: #25303f; text-wrap: pretty; }

  .scopebox {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 14px;
    padding: 0 2px;
    margin-bottom: 20px;
  }
  .scope-label { font: 600 9.5px var(--mono); letter-spacing: .12em; color: var(--ink-ghost); padding-top: 3px; }
  .scope-body { font-size: 13px; line-height: 1.7; color: var(--ink-faint); }

  .links { display: flex; gap: 7px; flex-wrap: wrap; }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--ink);
    color: #fff;
    font-size: 12.5px;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 999px;
    transition: background .16s ease;
  }
  .links a:hover { background: var(--dark); color: #fff; }
  .links a span { font: 400 11px var(--mono); color: #8fb4f8; }

  /* ---------- 꼭지 ---------- */
  .part { margin-top: 12px; }
  .part h3 { font-size: 17px; font-weight: 700; letter-spacing: -.015em; }
  .lede {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-faint);
    margin-top: 5px;
    max-width: 74ch;
  }
  .blocks { display: grid; gap: 14px; margin-top: 15px; }

  .decisions { display: grid; gap: 26px; }
  .dno {
    font: 700 9.5px var(--mono);
    letter-spacing: .14em;
    color: #fff;
    background: var(--accent);
    border-radius: 5px;
    padding: 3px 8px;
    display: inline-block;
    margin-bottom: 10px;
  }

  /* ---------- 회고 ---------- */
  .results { display: grid; gap: 6px; margin-top: 14px; }
  .results li {
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    padding-left: 15px;
    position: relative;
  }
  .results li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--good);
    font-weight: 800;
    font-size: 11px;
  }

  .tshoot { display: grid; gap: 9px; margin-top: 14px; }
  .tshoot > div { display: grid; grid-template-columns: 78px 1fr; gap: 14px; }
  .tshoot dt { font: 600 10px var(--mono); letter-spacing: .1em; color: var(--ink-ghost); padding-top: 2px; }
  .tshoot dd { font-size: 13px; line-height: 1.7; color: var(--ink-soft); }
  .tshoot .is-lesson dt { color: var(--accent); }
  .tshoot .is-lesson dd { color: var(--ink); font-weight: 600; }

  .debt-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
    margin-top: 15px;
  }
  .debt-cols h4 {
    font: 600 9.5px var(--mono);
    letter-spacing: .14em;
    color: var(--ink-ghost);
    margin-bottom: 9px;
  }
  .debt, .plan { display: grid; gap: 7px; }
  .debt li, .plan li {
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    padding-left: 16px;
    position: relative;
  }
  .debt li::before { content: "△"; position: absolute; left: 0; color: var(--warn); font-size: 10px; }
  .plan li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-size: 11px; }

  @media (max-width: 860px) {
    .bname { font-size: 24px; }
    .snum { font-size: 44px; border-bottom-width: 4px; }
    .shead h2 { font-size: 23px; }
    .wcols { grid-template-columns: 1fr; gap: 16px; }
    .tshoot > div, .scopebox { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
