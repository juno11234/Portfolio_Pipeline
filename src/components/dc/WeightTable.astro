---
/**
 * 가중치 표 — 조건별 확률 분포. 값의 색으로 '무엇이 0이고 무엇이 Config 화됐나'를 보인다.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: bond.dc.html 의 `가중치 조건 · Normal · Elite · Event · Camping` 표.
 *
 * 다른 표들과 셀 색 규칙이 다르다 — 값이 곧 의미다.
 *   보통 값(0.70)   — 진한 회색(#44454a).
 *   0 값(0.00)      — 흐린 회색(#a0a1a6). '이 조건에선 안 나온다'를 눈에서 지운다.
 *   Config 값(Cfg)  — 파랑(#1d4ed8). 하드코딩이 아니라 외부화됐다는 표시.
 * 첫 열의 조건 이름은 모노, 그 안의 괄호말(하드코딩·Config)은 다시 색으로 성격을 준다.
 *
 * 그래서 셀 값을 그냥 문자열이 아니라 {text, tone} 으로 받는다. 색을 콘텐츠에서 정하지 않고
 * tone 으로 정해, 같은 0 값이 문서 어디서나 같은 흐린 회색이 되게 한다.
 */
interface Cell {
  text: string;
  /** normal(진회색) · zero(흐린 회색) · cfg(파랑) */
  tone?: 'normal' | 'zero' | 'cfg';
}

interface Row {
  /** 첫 열 조건 이름. 예: layer < 4 */
  cond: string;
  /** 조건 옆 괄호말. 예: (하드코딩) · (Config) */
  condNote?: string;
  /** 괄호말 색. hard(회색) · cfg(파랑) */
  condTone?: 'hard' | 'cfg';
  /** 나머지 열 값들. headers 개수 - 1 개. */
  cells: Cell[];
}

interface Props {
  /** 첫 칸은 왼쪽 정렬, 나머지는 오른쪽 정렬. */
  headers: string[];
  rows: Row[];
  /** 원본이 이 자리에 박아둔 margin. 예: `16px 0 4px` */
  margin: string;
}

const { headers, rows, margin } = Astro.props;

const TH_LEFT =
  "text-align:left;font:600 10px 'JetBrains Mono',monospace;letter-spacing:.06em;color:#8a8b90;text-transform:uppercase;padding:9px 11px;border-bottom:1.5px solid rgba(20,22,26,.16)";
const TH_RIGHT =
  "text-align:right;font:600 10px 'JetBrains Mono',monospace;color:#8a8b90;padding:9px 11px;border-bottom:1.5px solid rgba(20,22,26,.16)";
const TD = 'padding:9px 11px;border-bottom:1px solid rgba(20,22,26,.07)';
const CELL_COLOR: Record<string, string> = { normal: '#44454a', zero: '#a0a1a6', cfg: '#1d4ed8' };
---

<table style={`width:100%;border-collapse:collapse;margin:${margin};font-size:12.5px`}>
  <thead>
    <tr>
      {headers.map((h, i) => <th style={i === 0 ? TH_LEFT : TH_RIGHT}>{h}</th>)}
    </tr>
  </thead>
  <tbody>
    {rows.map((r) => (
      <tr>
        <td style={`${TD};color:#17181a;font-family:'JetBrains Mono',monospace;font-size:11.5px`}>{r.cond}{r.condNote !== undefined && (
          <>{' '}<span style={r.condTone === 'cfg' ? 'color:#1d4ed8' : 'color:#a0a1a6'}>{r.condNote}</span></>
        )}</td>
        {r.cells.map((c) => (
          <td style={`${TD};text-align:right;font-family:'JetBrains Mono',monospace;color:${CELL_COLOR[c.tone ?? 'normal']}`}>{c.text}</td>
        ))}
      </tr>
    ))}
  </tbody>
</table>
