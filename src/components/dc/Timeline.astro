---
/**
 * 번호 타임라인 — 동그란 번호를 세로선으로 이어 순서를 보인다.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: design.html 의 `초기화 시퀀스 — 의존 순서를 await로 직렬화` 덩어리.
 *
 * 원본이 첫 단계만 다르게 그린다.
 *   첫 단계   — 파랑으로 채운 동그라미 + 그라데이션 세로선(#2563eb→#cddcfb)
 *   가운데    — 흰 동그라미에 파란 테두리 + 연파랑 세로선
 *   마지막    — 흰 동그라미. 세로선도 아래 여백도 없다.
 * 진입점이 어디인지 색만 보고 알게 하려는 것이다. 그 규칙을 그대로 뒀다.
 */
import { rich } from '../../lib/rich';

interface Step {
  title: string;
  /** 제목 오른쪽에 붙는 작은 배지. 예: await. 없으면 안 붙는다. */
  badge?: string;
  body: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;

/* 원본이 단계마다 반복하는 style */
const DOT_BASE =
  "flex:none;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font:700 12px 'JetBrains Mono',monospace;z-index:1";
const DOT_FIRST = `${DOT_BASE.replace('border-radius:50%;', 'border-radius:50%;background:#2563eb;color:#fff;')};box-shadow:0 2px 8px rgba(37,99,235,.3)`;
const DOT_REST = DOT_BASE.replace('border-radius:50%;', 'border-radius:50%;background:#fff;border:2px solid #2563eb;color:#1d4ed8;');
const LINE_BASE = 'position:absolute;left:15px;top:32px;bottom:-6px;width:2px';
---

<div style="position:relative;padding-left:6px">
  {steps.map((s, i) => {
    const last = i === steps.length - 1;
    return (
      <div
        style={
          last
            ? 'display:flex;gap:16px;align-items:flex-start;position:relative'
            : 'display:flex;gap:16px;align-items:flex-start;padding-bottom:18px;position:relative'
        }
      >
        {/* 마지막 단계 아래로는 이을 곳이 없어 선을 두지 않는다 */}
        {last === false && (
          <div style={i === 0 ? `${LINE_BASE};background:linear-gradient(#2563eb,#cddcfb)` : `${LINE_BASE};background:#cddcfb`}></div>
        )}
        <div style={i === 0 ? DOT_FIRST : DOT_REST}>{i + 1}</div>
        {/*
          공백은 배지가 있을 때만 넣는다. 원본이 그렇다 —
          배지 없는 단계는 제목 뒤가 바로 닫힌다. 공백을 밖에 두면 배지 없는 줄에
          꼬리 공백이 남아 원본과 어긋난다.
        */}
        <div style="padding-top:3px"><div style="font-size:14px;font-weight:700;color:#17181a">{s.title}{s.badge !== undefined && (
          <>{' '}<span style="font:600 9.5px 'JetBrains Mono',monospace;color:#fff;background:#2563eb;border-radius:4px;padding:2px 6px;margin-left:4px">{s.badge}</span></>
        )}</div><div style="font-size:12.5px;color:#55565a;margin-top:3px" set:html={rich(s.body)} /></div>
      </div>
    );
  })}
</div>
