---
/**
 * 그림 2장 나란히 — 각 그림 아래 캡션이 흰 띠로 붙는다.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: bond.dc.html 의 `속도선` / `실루엣` 셰이더 비교.
 *
 * BeforeAfter(회고의 텍스처 전/후)와 다르다 — 저쪽은 결과+설정 두 이미지에 판정 색이 붙는
 * '전후 비교'이고, 이쪽은 두 결과를 그냥 나란히 보이는 '카탈로그'다. 캡션도 아래 흰 띠 하나뿐.
 * Figure(단일)와도 다르다 — 2열이고 캡션이 figcaption 안이 아니라 그림 프레임 안에 든다.
 *
 * 각 칸은 그림 뒤 배경색을 따로 받는다(속도선은 검정 #0f0f10 위, 실루엣은 흰색 위).
 * 원본이 한쪽은 픽셀 크기를 박고 한쪽은 100%로 두는데, 그 차이(explicit)까지 값으로 받는다.
 */
import { rich } from '../../lib/rich';

interface Cell {
  src: string;
  alt: string;
  /** 그림 뒤 배경. 예: #0f0f10 · #fff */
  background: string;
  /**
   * 이미지 크기. 원본이 한쪽은 `376px × 191px` 로 박고 한쪽은 `100% auto` 로 둔다.
   * explicit 이면 픽셀, 없으면 폭 100%.
   */
  explicit?: { width: number; height: number };
  /** 캡션. `**굵게**` 를 쓸 수 있다. */
  caption: string;
}

interface Props {
  cells: [Cell, Cell];
  /** 원본이 이 자리에 박아둔 margin. 예: `14px 0 4px` */
  margin: string;
}

const { cells, margin } = Astro.props;

const CAP = "padding:9px 12px;background:#fff;border-top:1px solid rgba(20,22,26,.08);font:500 11px 'JetBrains Mono',monospace;color:#55565a";
---

<div style={`display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:${margin}`}>
  {cells.map((c) => (
    <figure style={`margin:0;border:1px solid rgba(20,22,26,.12);border-radius:12px;overflow:hidden;background:${c.background}`}>
      {c.explicit !== undefined
        ? <img src={c.src} alt={c.alt} style={`display: block; width: ${c.explicit.width}px; height: ${c.explicit.height}px`} />
        : <img src={c.src} alt={c.alt} style="display:block;width:100%;height:auto" />}
      <figcaption style={CAP} set:html={rich(c.caption)} />
    </figure>
  ))}
</div>
