---
/**
 * 회고 카드 — 아쉬운 점 제목 + 설명 + 파란 '배운 점' 박스를 2열로.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: bond.dc.html 의 `다음엔 순서를 바꾼다`(CI/CD 지연 · 버티컬 슬라이스 과대).
 *
 * 가이드 ⑤: "'아쉬운 점 없습니다'는 0점. 기술 부채를 인지하고 개선을 제시하는 사람이
 * 성장 가능성을 인정받습니다." 그래서 각 카드가 **문제(제목·설명) + 배운 점(파란 박스)** 을
 * 반드시 짝으로 갖는다. 아쉬운 점만 적고 끝내면 반성문이지 회고가 아니다.
 *
 * 뱀서라이크의 회고(debt 표 + plan 목록)와 담는 내용은 같지만 모양이 다르다 —
 * Bond 는 '문제 + 그래서 배운 것'을 한 카드에 묶었다. 두 방식 다 허용한다.
 */
import { rich } from '../../lib/rich';

interface Card {
  title: string;
  body: string;
  /** 파란 박스 안 배운 점. `**굵게**` 를 쓸 수 있다. */
  lesson: string;
}

interface Props {
  cards: Card[];
  /** 원본이 이 자리에 박아둔 margin. 예: `16px 0 4px` */
  margin: string;
}

const { cards, margin } = Astro.props;

const CARD = 'border:1px solid rgba(20,22,26,.1);border-radius:13px;padding:16px 18px;background:#fff';
const LESSON = 'font-size:12px;line-height:1.55;color:#1d4ed8;background:#eef3ff;border:1px solid #cddcfb;border-radius:8px;padding:9px 11px';
---

<div style={`display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:${margin}`}>
  {cards.map((c) => (
    <div style={CARD}>
      <div style="font-size:13.5px;font-weight:800;color:#17181a;margin-bottom:8px">{c.title}</div>
      <div style="font-size:12.5px;line-height:1.6;color:#55565a;margin-bottom:10px" set:html={rich(c.body)} />
      <div style={LESSON} set:html={rich(c.lesson)} />
    </div>
  ))}
</div>
