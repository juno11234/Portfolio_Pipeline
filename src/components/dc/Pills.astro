---
/**
 * 개요 맨 위 알약 줄 — 인원 · 기간 · 엔진 · 도구.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: 두 문서의 `1인 개발` / `4인 팀 프로젝트` 로 시작하는 줄.
 *
 * 원래 Overview.astro 안에 있었는데 Bond 를 올려보고 쪼갰다.
 * 개요의 **가운데는 문서마다 다르지만**(뱀서=WHAT/WHY · Bond=목표 카드) 알약 줄은 둘이 같다.
 * 같은 것과 다른 것을 갈라놔야 다음 프로젝트에서 또 뜯어고치지 않는다.
 *
 * 회고의 측정 조건 알약(ConditionPills)과 다르다 — 저쪽은 회색 · 반경 5px 이다.
 */
interface Props {
  items: string[];
}

const { items } = Astro.props;

const PILL =
  "font:600 10.5px 'JetBrains Mono',monospace;color:#1d4ed8;background:#eef3ff;border:1px solid #cddcfb;border-radius:20px;padding:5px 11px";
---

<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:26px">
  {items.map((p) => <span style={PILL}>{p}</span>)}
</div>
