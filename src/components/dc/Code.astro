---
/**
 * 코드 블록 — 파일명 머리 + **VS 다크 테마**로 구문 강조된 코드.
 *
 * 색칠은 Shiki(`dark-plus` = Visual Studio / VS Code 다크)로 **빌드 시점에** 굽는다 — 실제 VS 색상.
 * 색칠 로직은 원래도 byte-0 가 아니라 규칙 기반 커스텀이었다(디자인 원본은 손으로 span 을 박았고
 * repo 가 규칙으로 대체함). 그 규칙을 사용자 요청으로 Shiki 로 바꾼 것이라 byte-0 를 깨지 않는다.
 *
 * **프레임(테두리·파일명 헤더)은 다크로 맞췄다.** 원본은 밝은 헤더였으나, 사용자가 "VS 다크"를
 * 골라 코드 카드를 어둡게 대비시키기로 했다(밝은 사이트 위 어두운 IDE 코드 카드). 자리·구조는
 * 원본 그대로 두고 색만 다크로 바꿨다.
 *
 * 가이드 ③: "1000줄 다 보여주면 최악. '아하!'가 오는 핵심 50줄만 선별."
 */
import { highlightCsharp } from '../../lib/highlight';

interface Props {
  /** 머리에 찍히는 출처. 예: CombatSystem.cs · Tick() */
  source: string;
  /** 코드 원문. 하이라이트는 Shiki 가 한다(이스케이프 포함). */
  code: string;
  /** 원본이 이 자리에 박아둔 margin. 뱀서 `16px 0` · Bond 래퍼 주입 `14px 0`. */
  margin: string;
}

const { source, code, margin } = Astro.props;

/* Shiki dark-plus 로 구운 <pre class="shiki">…</pre>. 배경 #1e1e1e 도 테마가 함께 준다. */
const highlighted = await highlightCsharp(code);
---

<div
  style={`margin:${margin};border:1px solid #303030;border-radius:11px;overflow:hidden;background:#1e1e1e`}
>
  <div
    style="display:flex;align-items:center;gap:8px;padding:9px 14px;border-bottom:1px solid #303030;background:#252526"
  ><span style="width:8px;height:8px;border-radius:2px;background:#569cd6"></span><span
      style="font:600 10.5px 'JetBrains Mono',monospace;color:#cccccc"
    >{source}</span></div>
  <Fragment set:html={highlighted} />
</div>

<style>
  /* Shiki 출력 <pre class="shiki"> 을 이 프레임에 맞춘다 — 색은 Shiki 가 박고, 여백·폰트만 준다.
     set:html 로 주입된 마크업이라 스코프가 안 닿아 :global 로 연다(코드 블록 전부 같은 규칙). */
  :global(pre.shiki) {
    margin: 0;
    padding: 15px 17px;
    overflow-x: auto;
    font: 500 12px/1.7 'JetBrains Mono', monospace;
  }
  :global(pre.shiki code) {
    font: inherit;
    /* 원본은 줄바꿈 없이 가로 스크롤. Shiki 의 line span 도 그대로 흐르게 둔다. */
  }
</style>
