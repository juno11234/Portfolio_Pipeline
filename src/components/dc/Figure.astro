---
/**
 * 그림 + 아래에 붙는 캡션.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: design.html 의 개요 대표 화면 · `SHADER GRAPH` · `PROFILE ANALYZER` 세 곳.
 *
 * 원본이 액자를 두 가지로 그린다. 값을 세어보고 알았다.
 *   hero — 반경 13px · 그림자 .12 · 테두리 .1. 개요의 대표 화면 딱 하나.
 *          뱀서라이크와 Bond 의 개요 figure 가 둘 다 이 값이라 우연이 아니다.
 *   body — 반경 12px · 그림자 .1 · 테두리 .12. 본문에 끼는 그림들.
 * 대표 화면만 조금 더 크고 둥글게 떠 있다. 첫 화면이 문서의 표지 노릇을 하기 때문이다.
 *
 * 캡션이 필수인 이유는 스키마의 imageBlock 과 같다 —
 * 무엇을 보라는 건지 말해주지 않는 이미지는 증거가 아니라 장식이다.
 */
import { rich } from '../../lib/rich';

interface Props {
  src: string;
  alt: string;
  /** 개요의 대표 화면인지(hero), 본문에 끼는 그림인지(body) */
  kind: 'hero' | 'body';
  /**
   * 그림 뒤 배경. 스크린샷의 여백 색과 이어 붙이려고 원본이 그림마다 정한다.
   * 예: 뱀서라이크 대표 화면 #1a120b · ShaderGraph 캡처 #232323
   */
  background: string;
  /** 캡션 앞 배지. 예: SCREENSHOT · SHADER GRAPH · PROFILE ANALYZER */
  label: string;
  /** 캡션 본문. `**굵게**` 와 `` `코드` `` 를 쓸 수 있다. */
  caption: string;
  /** 원본이 이 자리에 박아둔 margin. 예: `0 0 24px` */
  margin: string;
}

const { src, alt, kind, background, label, caption, margin } = Astro.props;

const FRAME =
  kind === 'hero'
    ? `border:1px solid rgba(20,22,26,.1);border-radius:13px;overflow:hidden;box-shadow:0 6px 24px rgba(20,22,26,.12);background:${background}`
    : `border:1px solid rgba(20,22,26,.12);border-radius:12px;overflow:hidden;box-shadow:0 6px 24px rgba(20,22,26,.1);background:${background}`;
---

<figure style={`margin:${margin}`}>
  <div style={FRAME}>
    <img src={src} alt={alt} style="display:block;width:100%;height:auto" />
  </div>
  <figcaption
    style="display:flex;align-items:center;gap:8px;margin-top:9px;font:500 11px 'JetBrains Mono',monospace;color:#8a8b90"
  ><span
      style="font:700 8.5px 'JetBrains Mono',monospace;letter-spacing:.1em;color:#fff;background:#2563eb;border-radius:4px;padding:2px 6px"
    >{label}</span>{' '}<Fragment set:html={rich(caption)} /></figcaption>
</figure>
