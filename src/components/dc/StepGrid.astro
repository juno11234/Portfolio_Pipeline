---
/**
 * 단계 그리드 — 번호 배지 + 이름 + 한 줄 설명을 2열로 채운다.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: bond.dc.html 의 `GenerateMap — 10단계 동기 파이프라인` 덩어리.
 *
 * Timeline(세로 한 줄, 동그란 번호)과 다르다 — 단계가 10개라 세로로 세우면 너무 길어서
 * 2열 그리드로 접었다. 순서는 왼쪽 위 → 아래 → 오른쪽 위 → 아래로 읽는다(grid 흐름).
 * 마지막 단계 배지만 검정이다 — 파이프라인의 끝(AssignBossGroups)을 색으로 닫는다.
 *
 * 각 행은 아래 테두리로 나뉘는데, 각 열의 **마지막 행만** 테두리가 없다.
 */
interface Step {
  /** 단계 이름. 예: DetermineNodeCounts */
  name: string;
  /** 한 줄 설명. 예: 0층·마지막층=1, 중간층 rng */
  note: string;
}

interface Props {
  steps: Step[];
  /** 원본이 이 자리에 박아둔 margin. 예: `16px 0` */
  margin: string;
}

const { steps, margin } = Astro.props;

const ROW = 'display:flex;gap:11px;align-items:flex-start;padding:8px 0';
const BADGE = "flex:none;width:22px;height:22px;border-radius:6px;background:#2563eb;color:#fff;display:flex;align-items:center;justify-content:center;font:700 10px 'JetBrains Mono',monospace";
/* 마지막(10) 배지만 검정 + 두 자리라 글자가 작다 */
const BADGE_LAST = "flex:none;width:22px;height:22px;border-radius:6px;background:#17181a;color:#fff;display:flex;align-items:center;justify-content:center;font:700 9px 'JetBrains Mono',monospace";

/**
 * 2열 그리드에서 각 열의 마지막 행만 아래 테두리가 없다.
 * 원본은 홀수 개(위 9개는 테두리, 마지막 10만 없음)가 아니라, 두 열로 나뉘었을 때
 * 각 열 바닥 행만 뺀다. steps 가 10개면 인덱스 8·9(열별 마지막)가 테두리 없음.
 */
const rowCount = Math.ceil(steps.length / 2);
const isColBottom = (i: number): boolean => {
  const row = Math.floor(i / 2);
  return row === rowCount - 1;
};
const LINE = 'border-bottom:1px solid rgba(20,22,26,.06)';
---

<div style={`border:1px solid rgba(20,22,26,.1);border-radius:12px;background:#fbfbfa;padding:16px 18px;margin:${margin}`}>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px 22px">
    {steps.map((s, i) => (
      <div style={isColBottom(i) ? ROW : `${ROW};${LINE}`}>
        <span style={i === steps.length - 1 ? BADGE_LAST : BADGE}>{i + 1}</span>
        <div><div style="font:700 11.5px 'JetBrains Mono',monospace;color:#17181a">{s.name}</div><div style="font-size:11px;color:#6b6b6b">{s.note}</div></div>
      </div>
    ))}
  </div>
</div>
