---
/**
 * 채널 표 — 이름(모노 잉크) · 자료구조(모노 파랑) · 방향(회색).
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: bond.dc.html 의 `씬 경계를 잇는 정적 채널 5종` 표.
 *
 * DataTable · DebtTable 과 또 다르다 — **둘째 칸이 모노 파란색 11.5px** 이다. 자료구조가
 * 코드 타입(`Stack<Action<StageResult>>`)이라 코드처럼 칠했다. padding 도 `10px 11px` 로 다르다.
 * "표는 다 비슷하다" 고 합쳤으면 이 열의 파란색이 사라졌을 것이다.
 *
 * 자료구조 칸은 C# 제네릭이 그대로 오므로 rich() 로 이스케이프한다.
 */
import { rich } from '../../lib/rich';

interface Props {
  /** 세 칸. 예: 채널 · 자료구조 · 방향 */
  headers: [string, string, string];
  rows: Array<{ name: string; type: string; direction: string }>;
  /** 원본이 이 자리에 박아둔 margin. 예: `6px 0 8px` */
  margin: string;
}

const { headers, rows, margin } = Astro.props;

const TH =
  "text-align:left;font:600 10px 'JetBrains Mono',monospace;letter-spacing:.06em;color:#8a8b90;text-transform:uppercase;padding:9px 11px;border-bottom:1.5px solid rgba(20,22,26,.16)";
const TD = 'padding:10px 11px;border-bottom:1px solid rgba(20,22,26,.07)';
---

<table style={`width:100%;border-collapse:collapse;margin:${margin};font-size:12.5px`}>
  <thead>
    <tr>{headers.map((h) => <th style={TH}>{h}</th>)}</tr>
  </thead>
  <tbody>
    {rows.map((r) => (
      <tr>
        <td style={`${TD};font-family:'JetBrains Mono',monospace;color:#17181a;font-weight:600`}>{r.name}</td>
        <td style={`${TD};font-family:'JetBrains Mono',monospace;font-size:11.5px;color:#1d4ed8`} set:html={rich(r.type)} />
        <td style={`${TD};color:#44454a`} set:html={rich(r.direction)} />
      </tr>
    ))}
  </tbody>
</table>
