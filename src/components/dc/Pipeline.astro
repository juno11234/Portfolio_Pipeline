---
/**
 * 파이프라인 — 단계 상자를 화살표로 이어 가로로 늘어놓는다.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** style 문자열을 손대지 않았다.
 * 원본 대조: design.html 의 `데이터 파이프라인 — TSV에서 런타임까지` 덩어리.
 *
 * 뱀서라이크 '데이터 파이프라인'과 Bond 'Config 로더 3단'이 같은 모양이다.
 *
 * 단계가 두 종류다. **이게 이 그림의 요점이다.**
 *   editor  — 점선 회색. 빌드 전에만 도는 것. 게임에는 안 들어간다.
 *   runtime — 파란 실선. 실제로 기기에서 도는 것.
 * 어디까지가 에디터 일이고 어디부터 런타임인지를 색으로 가른다.
 * 그 경계를 넘는 화살표만 ⇒ 이고 나머지는 → 다.
 */
interface Stage {
  /** 위 작은 글씨. 예: 에디터 타임 · 런타임 */
  label: string;
  /** 아래 큰 글씨. 예: GameDataContainer */
  name: string;
  kind: 'editor' | 'runtime';
  /** 이 단계 **뒤에** 오는 화살표. 마지막 단계에는 없다. 예: → · ⇒ */
  arrow?: string;
  /** 화살표를 파랑으로 칠할지. 원본은 런타임으로 넘어가는 화살표부터 파랑이다. */
  arrowAccent?: boolean;
}

interface Props {
  stages: Stage[];
  /** 원본이 이 자리에 박아둔 margin. 예: `16px 0` */
  margin: string;
}

const { stages, margin } = Astro.props;

/* 원본이 단계마다 반복하는 style */
const BOX: Record<string, string> = {
  editor: 'flex:1;min-width:120px;text-align:center;background:#fafafa;border:1px dashed rgba(20,22,26,.2);border-radius:9px;padding:11px 8px',
  runtime: 'flex:1;min-width:120px;text-align:center;background:#eef3ff;border:1px solid #cddcfb;border-radius:9px;padding:11px 8px',
};
const LABEL: Record<string, string> = {
  editor: "font:600 8.5px 'JetBrains Mono',monospace;letter-spacing:.1em;color:#a0a1a6;margin-bottom:6px",
  runtime: "font:600 8.5px 'JetBrains Mono',monospace;letter-spacing:.1em;color:#2563eb;margin-bottom:6px",
};
const NAME: Record<string, string> = {
  editor: "font:600 11px 'JetBrains Mono',monospace;color:#26272b",
  runtime: "font:600 11px 'JetBrains Mono',monospace;color:#1d4ed8",
};
---

<div
  style={`display:flex;flex-wrap:wrap;align-items:stretch;gap:8px;margin:${margin};padding:16px;border:1px solid rgba(20,22,26,.1);border-radius:12px;background:#fff`}
>
  {stages.map((s) => (
    <>
      <div style={BOX[s.kind]}><div style={LABEL[s.kind]}>{s.label}</div><div style={NAME[s.kind]}>{s.name}</div></div>
      {s.arrow !== undefined && (
        <div style={s.arrowAccent === true ? 'display:flex;align-items:center;color:#2563eb;font-weight:700' : 'display:flex;align-items:center;color:#93b4f5;font-weight:700'}>{s.arrow}</div>
      )}
    </>
  ))}
</div>
