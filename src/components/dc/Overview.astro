---
/**
 * ① 개요 — 메타 알약 · 스크린샷 · WHAT/WHY · 10초 요약.
 *
 * **claude.ai/design 의 마크업을 글자 그대로 옮긴 것이다.** 다시 그리지 않았다.
 * style 문자열은 원본과 한 글자도 다르지 않고, 값이 들어갈 자리만 뚫었다.
 *
 * 눈으로 보고 "비슷하게" 만들면 매번 조금씩 깎여서 결국 원본만 못해진다.
 * 모양을 바꾸고 싶으면 Claude Design 에서 고치고 여기로 다시 떠 온다.
 */
import { rich } from '../../lib/rich';

interface Props {
  /** 인원 · 기간 · 엔진 · 도구. 원본은 네 개를 한 줄로 늘어놓는다. */
  pills: string[];
  screenshot: { src: string; alt: string; caption: string };
  what: string;
  why: string;
  /** 10초 요약. 가이드: "결론부터 제시해 10초 안에 핵심이 잡혀야 합니다." */
  tldr: { label: string; body: string };
}

const { pills, screenshot, what, why, tldr } = Astro.props;

/* 원본이 알약마다 똑같이 반복하는 style. 한 곳에 두고 돌린다. */
const PILL =
  "font:600 10.5px 'JetBrains Mono',monospace;color:#1d4ed8;background:#eef3ff;border:1px solid #cddcfb;border-radius:20px;padding:5px 11px";
---

<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:26px">
  {pills.map((p) => <span style={PILL}>{p}</span>)}
</div>

<figure style="margin:0 0 24px">
  <div
    style="border:1px solid rgba(20,22,26,.1);border-radius:13px;overflow:hidden;box-shadow:0 6px 24px rgba(20,22,26,.12);background:#1a120b"
  >
    <img src={screenshot.src} alt={screenshot.alt} style="display:block;width:100%;height:auto" />
  </div>
  <figcaption
    style="display:flex;align-items:center;gap:8px;margin-top:9px;font:500 11px 'JetBrains Mono',monospace;color:#8a8b90"
  ><span
      style="font:700 8.5px 'JetBrains Mono',monospace;letter-spacing:.1em;color:#fff;background:#2563eb;border-radius:4px;padding:2px 6px"
    >SCREENSHOT</span> {screenshot.caption}</figcaption>
</figure>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:24px">
  {/* WHAT 은 진한 테두리, WHY 는 흐린 테두리 — 원본이 둘을 구분해 둔 그대로다 */}
  <div style="border-left:3px solid #2563eb;padding:3px 0 3px 15px">
    <div
      style="font:600 10px 'JetBrains Mono',monospace;letter-spacing:.14em;color:#2563eb;margin-bottom:7px"
    >WHAT</div>
    <div style="font-size:14px;line-height:1.62;color:#33343a" set:html={rich(what)} />
  </div>
  <div style="border-left:3px solid rgba(37,99,235,.28);padding:3px 0 3px 15px">
    <div
      style="font:600 10px 'JetBrains Mono',monospace;letter-spacing:.14em;color:#8a8b90;margin-bottom:7px"
    >WHY</div>
    <div style="font-size:14px;line-height:1.62;color:#33343a" set:html={rich(why)} />
  </div>
</div>

<div style="background:#eef3ff;border:1px solid #cddcfb;border-radius:13px;padding:20px 22px;margin-bottom:30px">
  <div
    style="font:600 10px 'JetBrains Mono',monospace;letter-spacing:.14em;color:#2563eb;margin-bottom:9px"
  >{tldr.label}</div>
  <div style="font-size:14.5px;line-height:1.68;color:#25303f;text-wrap:pretty" set:html={rich(tldr.body)} />
</div>
