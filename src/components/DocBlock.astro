---
/**
 * 기술 문서 블록 하나를 그린다.
 *
 * 형태는 claude.ai/design 의 "VamSirLike Document" 를 따른다.
 * 원본 PDF에서는 이 내용들이 72ppi 래스터 이미지에 묻혀 검색도 복사도 안 됐다. 여기서는 전부 텍스트다.
 */
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { renderMermaid } from '../lib/mermaid';
import { rich } from '../lib/rich';

type Doc = CollectionEntry<'projectDocs'>['data'];
type Block = Doc['sections'][number]['parts'][number]['blocks'][number];

interface Props {
  block: Block;
}

const { block } = Astro.props;

/* 빌드 시점에 SVG로 굽는다. 브라우저로 나가는 JS는 0이다. */
const mermaidSvg = block.type === 'mermaid' ? await renderMermaid(block.source) : null;
---

{block.type === 'mermaid' && mermaidSvg !== null && (
  <figure class="dia">
    <div class="dia-body" set:html={mermaidSvg} />
    <figcaption>
      <span class="dia-label">DIAGRAM</span>
      {block.question}
    </figcaption>
  </figure>
)}

{block.type === 'image' && (
  <figure class="shot">
    <Image src={block.src} alt={block.caption} widths={[720, 1440]} sizes="(max-width: 860px) 100vw, 720px" />
    <figcaption>
      <span class="slabel">{block.label}</span>
      {block.caption}
    </figcaption>
  </figure>
)}

{block.type === 'prose' && (
  <div class="prose">
    {block.paragraphs.map((p) => <p set:html={rich(p)} />)}
  </div>
)}

{block.type === 'code' && (
  <div class="code">
    <p class="api"><span>사용법</span><code>{block.api}</code></p>
    <div class="scroll">
      <pre><code>{block.code}</code></pre>
    </div>
    <ul class="notes">
      {block.notes.map((n) => (
        <li>
          <span class="at">{n.at}</span>
          <span class="why" set:html={rich(n.why)} />
        </li>
      ))}
    </ul>
  </div>
)}

{block.type === 'points' && (
  <ul class="points">
    {block.items.map((item) => (
      <li>
        <h4>{item.title}</h4>
        <p set:html={rich(item.body)} />
      </li>
    ))}
  </ul>
)}

{block.type === 'stack-table' && (
  <div class="scroll">
    <table class="tbl">
      <thead>
        <tr><th>분류</th><th>기술</th><th>사용 목적</th></tr>
      </thead>
      <tbody>
        {block.rows.map((row) => (
          <tr>
            <td class="cat">{row.category}</td>
            <td class="tech">{row.tech}</td>
            <td set:html={rich(row.purpose)} />
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

{block.type === 'table' && (
  <div class="scroll">
    <table class="tbl">
      <thead>
        <tr>{block.headers.map((h) => <th>{h}</th>)}</tr>
      </thead>
      <tbody>
        {block.rows.map((row) => (
          <tr>{row.map((cell, i) => <td class={i === 0 ? 'tech' : undefined}>{cell}</td>)}</tr>
        ))}
      </tbody>
    </table>
  </div>
)}

{block.type === 'layers' && (
  <div class="layers">
    <dl class="triplet">
      <div><dt>구성요소</dt><dd set:html={rich(block.components)} /></div>
      <div><dt>관계</dt><dd set:html={rich(block.relations)} /></div>
      <div><dt>흐름</dt><dd set:html={rich(block.flow)} /></div>
    </dl>

    {block.layers.map((layer) => (
      <>
        {layer.edge !== undefined && (
          <p class="edge"><span>{layer.edge}</span></p>
        )}
        <div class="layer">
          <div class="layer-head">
            <span class="layer-name">{layer.name}</span>
            {layer.note !== undefined && <span class="layer-note">{layer.note}</span>}
          </div>
          <div class="nodes">
            {layer.items.map((item) => (
              <div class:list={['node', { 'is-emphasis': item.emphasis === true }]}>
                <span class="node-name">{item.name}</span>
                {item.note !== undefined && <span class="node-note">{item.note}</span>}
              </div>
            ))}
          </div>
        </div>
      </>
    ))}
  </div>
)}

{block.type === 'metrics' && (
  <ul class="metrics">
    {block.items.map((m) => (
      <li>
        <p class="mlabel">{m.label}</p>
        <p class="mvals tnum">
          <span class="before">{m.before}</span>
          <span class="arrow" aria-hidden="true">→</span>
          <span class="after">{m.after}</span>
          <span class="delta">{m.delta}</span>
        </p>
      </li>
    ))}
  </ul>
)}

{block.type === 'before-after' && (
  <div class="ba">
    <div class="ba-cols">
      {[block.before, block.after].map((side, i) => (
        <div class:list={['ba-col', { 'is-after': i === 1 }]}>
          <h4>{side.label}</h4>
          <ul>{side.items.map((t) => <li set:html={rich(t)} />)}</ul>
        </div>
      ))}
    </div>
    <p class="lesson"><span>알게된 점</span>{block.lesson}</p>
  </div>
)}

<style>
  /* 좁은 화면에서 표만 옆으로 밀리게 한다. 페이지 전체가 밀리면 안 된다. */
  .scroll { overflow-x: auto; }

  /* ---------- Mermaid 다이어그램 ---------- */
  .dia {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  /* 넓은 다이어그램은 이 안에서만 밀린다. 페이지 전체가 밀리면 안 된다. */
  .dia-body { overflow-x: auto; padding: 20px 18px; }
  .dia-body :global(svg) { max-width: 100%; height: auto; display: block; margin: 0 auto; }
  .dia figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 10px 14px 12px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-faint);
  }
  .dia-label {
    flex: none;
    font: 700 8.5px var(--mono);
    letter-spacing: .14em;
    color: #fff;
    background: var(--accent);
    border-radius: 4px;
    padding: 3px 6px;
  }

  /* ---------- 스크린샷 ---------- */
  .shot {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .shot img { width: 100%; height: auto; display: block; }
  .shot figcaption {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 10px 14px 12px;
    border-top: 1px solid var(--line);
    font-size: 12px;
    line-height: 1.6;
    color: var(--ink-faint);
  }
  .slabel {
    flex: none;
    font: 700 8.5px var(--mono);
    letter-spacing: .14em;
    color: #fff;
    background: var(--accent);
    border-radius: 4px;
    padding: 3px 6px;
  }

  .prose { display: grid; gap: 12px; }
  .prose p { font-size: 14.5px; line-height: 1.75; color: var(--ink-soft); }

  /* ---------- 코드 + 설명 ---------- */
  .code { display: grid; gap: 10px; }
  .api { font-size: 12.5px; color: var(--ink-soft); }
  .api span {
    display: inline-block;
    font: 600 10px var(--mono);
    letter-spacing: .14em;
    color: var(--accent);
    margin-right: 9px;
  }
  .api code { font: 700 12.5px var(--mono); color: var(--ink); }
  .code pre {
    background: var(--dark-deep);
    color: var(--dark-ink);
    border-radius: 11px;
    padding: 16px 18px;
    font: 400 12px/1.75 var(--mono);
  }
  .notes { display: grid; gap: 6px; }
  .notes li {
    display: grid;
    grid-template-columns: minmax(96px, auto) 1fr;
    gap: 12px;
    font-size: 12.5px;
    line-height: 1.6;
  }
  .notes .at { font: 700 11.5px var(--mono); color: var(--accent); }
  .notes .why { color: var(--ink-soft); }

  /* ---------- 포인트 카드 ---------- */
  .points {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(232px, 1fr));
    gap: 9px;
  }
  .points li {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 11px;
    padding: 14px 16px 15px;
  }
  .points h4 { font-size: 13.5px; font-weight: 700; letter-spacing: -.01em; margin-bottom: 5px; }
  .points p { font-size: 12.5px; line-height: 1.65; color: var(--ink-soft); }

  /* ---------- 표 ---------- */
  .tbl { border-collapse: collapse; width: 100%; font-size: 13px; }
  .tbl th {
    text-align: left;
    font: 600 9.5px var(--mono);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-ghost);
    padding: 0 16px 9px 0;
    white-space: nowrap;
  }
  .tbl td {
    padding: 11px 16px 11px 0;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    line-height: 1.6;
    vertical-align: top;
  }
  .tbl .cat { font-weight: 700; color: var(--ink); white-space: nowrap; }
  .tbl .tech { font: 500 12.5px var(--mono); color: var(--accent); }

  /* ---------- 계층도 ---------- */
  .layers { display: grid; gap: 0; }
  /* 가이드 ②: 구성요소·관계·흐름. 그림만 있으면 독자가 해석하지 못한다. */
  .triplet { display: grid; gap: 9px; margin-bottom: 16px; }
  .triplet > div { display: grid; grid-template-columns: 66px 1fr; gap: 12px; }
  .triplet dt {
    font: 600 9.5px var(--mono);
    letter-spacing: .1em;
    color: #fff;
    background: var(--accent);
    border-radius: 5px;
    padding: 3px 0;
    text-align: center;
    height: fit-content;
  }
  .triplet dd { font-size: 13px; line-height: 1.68; color: var(--ink-soft); }

  .layer {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 11px;
    overflow: hidden;
  }
  .layer-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    background: var(--accent);
    padding: 9px 14px;
  }
  .layer-name { font: 700 11px var(--mono); letter-spacing: .12em; color: #fff; }
  .layer-note { font-size: 11px; color: rgba(255, 255, 255, .78); font-weight: 500; }
  .nodes { display: flex; flex-wrap: wrap; gap: 7px; padding: 13px 14px 14px; }
  .node {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 8px 12px;
    display: grid;
    gap: 1px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .node-name { font: 600 12px var(--mono); color: var(--ink); }
  .node-note { font-size: 10.5px; color: var(--ink-faint); }
  /* 이 문서가 설명하려는 핵심 객체 */
  .node.is-emphasis { background: var(--dark-deep); border-color: var(--dark-deep); }
  .node.is-emphasis .node-name { color: #fff; }
  .node.is-emphasis .node-note { color: #8fb4f8; }

  .edge { text-align: center; padding: 9px 0; }
  .edge span {
    font: 600 9px var(--mono);
    letter-spacing: .14em;
    color: var(--ink-faint);
    position: relative;
  }
  .edge span::before {
    content: "↓";
    display: block;
    font-size: 12px;
    letter-spacing: 0;
    color: var(--accent);
    margin-bottom: 2px;
  }

  /* ---------- 수치 ---------- */
  .metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 9px;
  }
  .metrics li {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 11px;
    padding: 13px 16px 14px;
  }
  .mlabel { font: 500 11px var(--mono); color: var(--ink-faint); margin-bottom: 5px; }
  .mvals { display: flex; align-items: baseline; gap: 7px; flex-wrap: wrap; }
  .before { font-size: 14px; font-weight: 600; color: var(--ink-ghost); }
  .arrow { color: var(--ink-ghost); font-size: 12px; }
  .after { font-size: 22px; font-weight: 800; color: var(--ink); letter-spacing: -.03em; }
  .delta {
    font: 700 10.5px var(--mono);
    color: var(--accent);
    background: var(--accent-tint);
    border: 1px solid var(--accent-line);
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* ---------- 전후 비교 ---------- */
  .ba { display: grid; gap: 10px; }
  .ba-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(224px, 1fr)); gap: 9px; }
  .ba-col {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 11px;
    padding: 14px 16px 15px;
  }
  .ba-col.is-after { background: var(--accent-tint); border-color: var(--accent-line); }
  .ba-col h4 { font: 600 9.5px var(--mono); letter-spacing: .14em; color: var(--ink-ghost); margin-bottom: 9px; }
  .ba-col.is-after h4 { color: var(--accent); }
  .ba-col li {
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    padding-left: 11px;
    position: relative;
  }
  .ba-col li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .62em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: currentColor;
    opacity: .4;
  }
  .lesson {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: 0 11px 11px 0;
    padding: 13px 16px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-soft);
  }
  .lesson span {
    display: inline-block;
    font: 700 9.5px var(--mono);
    letter-spacing: .1em;
    color: var(--accent);
    margin-right: 10px;
  }
</style>
