---
/**
 * 기술 문서 블록 하나를 **dc 컴포넌트로** 그린다.
 *
 * 스키마 블록(데이터층)을 받아 알맞은 dc 컴포넌트(템플릿층)에 넘긴다.
 * 스키마와 dc 의 모양이 어긋나는 곳은 여기서 어댑터로 잇는다 —
 * 예: 스키마 code 의 api → dc Code 의 source, table 의 string[][] → DataTable 의 {label,cells}.
 *
 * variant 필드가 같은 데이터를 여러 컴포넌트 중 하나로 보낸다(points·table·image·chips).
 * 그래프(class-diagram 등)는 스키마에 없다 — 전부 mermaid 로 온다.
 *
 * 여백은 여기서 **블록 종류별 규칙**으로 준다(디자인의 자리별 값이 아니라). 콘텐츠 파일은
 * 여백을 들지 않는다 — 3층 분리를 지키는 지점이다.
 */
import { renderMermaid } from '../lib/mermaid';
import { rich } from '../lib/rich';
import { cardsAreLong } from '../lib/cardLayout';

import Code from './dc/Code.astro';
import StackTable from './dc/StackTable.astro';
import DataTable from './dc/DataTable.astro';
import WeightTable from './dc/WeightTable.astro';
import ChannelTable from './dc/ChannelTable.astro';
import MetricsTable from './dc/MetricsTable.astro';
import Layers from './dc/Layers.astro';
import PrincipleCards from './dc/PrincipleCards.astro';
import StackCards from './dc/StackCards.astro';
import CheckCards from './dc/CheckCards.astro';
import MiniCards from './dc/MiniCards.astro';
import FlowCards from './dc/FlowCards.astro';
import DefectList from './dc/DefectList.astro';
import Figure from './dc/Figure.astro';
import FigureAside from './dc/FigureAside.astro';
import FigureGrid from './dc/FigureGrid.astro';
import ApiList from './dc/ApiList.astro';
import Callout from './dc/Callout.astro';
import StateChips from './dc/StateChips.astro';
import LoopChips from './dc/LoopChips.astro';
import FlowChips from './dc/FlowChips.astro';
import ConditionPills from './dc/ConditionPills.astro';
import ContrastBox from './dc/ContrastBox.astro';

// 블록 유니온이 넓어 정확한 타입을 매기기 번거롭다. 판별자(type)로 좁혀 읽으므로 unknown 으로 받는다.
interface Props {
  block: Record<string, unknown>;
}
const { block } = Astro.props;
const b = block as any;

/* 빌드 시점에 SVG로 굽는다. 브라우저로 나가는 JS는 0이다. */
const mermaidSvg = b.type === 'mermaid' ? await renderMermaid(b.source) : null;

/** points variant → dc 카드 컴포넌트로 넘길 값을 만든다. */
const cardItems = b.type === 'points' ? b.items : [];
---

{b.type === 'prose' && (
  <div class="prose">
    {b.paragraphs.map((p: string) => <p set:html={rich(p)} />)}
  </div>
)}

{b.type === 'code' && (
  <div class="code-wrap">
    <Code source={b.api} code={b.code} margin="16px 0 0" />
    <ul class="notes">
      {b.notes.map((n: { at: string; why: string }) => (
        <li><span class="at">{n.at}</span><span class="why" set:html={rich(n.why)} /></li>
      ))}
    </ul>
  </div>
)}

{b.type === 'points' && b.variant === 'numbered' && (
  <PrincipleCards margin="16px 0 4px" cards={cardItems.map((it: any, i: number) => ({ num: it.tag ?? String(i + 1).padStart(2, '0'), title: it.title, body: it.body }))} />
)}
{b.type === 'points' && b.variant === 'check' && (
  <CheckCards margin="16px 0 4px" cards={cardItems.map((it: any) => ({ title: it.title, body: it.body }))} />
)}
{b.type === 'points' && b.variant === 'mini' && (
  <MiniCards margin="14px 0" cards={cardItems.map((it: any) => ({ name: it.title, note: it.body }))} />
)}
{b.type === 'points' && b.variant === 'flow' && (
  <FlowCards margin="16px 0 4px" arrow="→" cards={cardItems.map((it: any) => ({ label: it.tag ?? '', title: it.title, body: it.body }))} />
)}
{b.type === 'points' && b.variant === 'defect' && (
  <DefectList margin="16px 0 4px" defects={cardItems.map((it: any, i: number) => ({ code: it.tag ?? `B${i + 1}`, title: it.title, body: it.body }))} />
)}
{/* stack — 자동 판정을 덮어쓰는 강제 세로 override. */}
{b.type === 'points' && b.variant === 'stack' && (
  <StackCards margin="16px 0 4px" cards={cardItems.map((it: any) => ({ title: it.title, body: it.body }))} />
)}
{/* plain(기본) — 렌더러가 본문 길이로 정한다: 짧으면 3열 격자(가로), 길면 전폭 세로(StackCards). */}
{b.type === 'points' && (b.variant === undefined || b.variant === 'plain') && (
  cardsAreLong(cardItems)
    ? <StackCards margin="16px 0 4px" cards={cardItems.map((it: any) => ({ title: it.title, body: it.body }))} />
    : <PrincipleCards margin="16px 0 4px" cards={cardItems.map((it: any) => ({ title: it.title, body: it.body }))} />
)}

{b.type === 'stack-table' && (
  <div class="scroll"><StackTable rows={b.rows} widths={[118, 180]} /></div>
)}

{b.type === 'table' && b.variant === 'weight' && (
  <div class="scroll"><WeightTable margin="16px 0 4px" headers={b.headers} rows={b.rows.map((r: string[]) => ({
    cond: r[0],
    cells: r.slice(1).map((c: string) => ({ text: c, tone: /^0(\.0+)?$/.test(c) ? 'zero' : (c === 'Cfg' ? 'cfg' : 'normal') })),
  }))} /></div>
)}
{b.type === 'table' && b.variant === 'channel' && (
  <div class="scroll"><ChannelTable margin="6px 0 8px" headers={b.headers} rows={b.rows.map((r: string[]) => ({ name: r[0], type: r[1], direction: r[2] }))} /></div>
)}
{b.type === 'table' && (b.variant === undefined || b.variant === 'plain') && (
  <div class="scroll"><DataTable margin="14px 0" headers={b.headers} rows={b.rows.map((r: string[]) => ({ label: r[0], cells: r.slice(1) }))} /></div>
)}

{b.type === 'layers' && (
  <div class="layers-wrap">
    <dl class="triplet">
      <div><dt>구성요소</dt><dd set:html={rich(b.components)} /></div>
      <div><dt>관계</dt><dd set:html={rich(b.relations)} /></div>
      <div><dt>흐름</dt><dd set:html={rich(b.flow)} /></div>
    </dl>
    <Layers
      headTracking=".08em"
      layers={b.layers.map((L: any) => ({
        name: L.name,
        note: L.note ?? '',
        edge: L.edge,
        items: L.items.map((it: any) => ({
          name: it.name,
          kind: it.kind ?? (it.emphasis === true ? 'emphasis' : 'normal'),
          body: it.body,
        })),
      }))}
    />
  </div>
)}

{b.type === 'metrics' && (
  <MetricsTable margin="14px 0 10px" headers={['지표', '최적화 전', '최적화 후', '개선']} rows={b.items} />
)}

{b.type === 'before-after' && (
  <ContrastBox
    margin="16px 0"
    past={{ label: b.before.label, items: b.before.items }}
    now={{ label: b.after.label, items: b.after.items }}
  />
)}

{b.type === 'image' && b.variant === 'aside' && (
  <FigureAside src={b.src.src} alt={b.caption} width={b.width ?? 330} background="#2b2b2b" label={b.label} caption={b.caption} size="sm" margin="18px 0 4px" />
)}
{b.type === 'image' && (b.variant === undefined || b.variant === 'below') && (
  <Figure src={b.src.src} alt={b.caption} kind="body" background="#fff" label={b.label} caption={b.caption} margin="18px 0 6px" />
)}

{b.type === 'figure-grid' && (
  <div class="scroll"><FigureGrid
    margin="16px 0 6px"
    cells={b.cells.map((c: any) => ({
      src: c.src.src,
      alt: c.caption,
      background: c.background,
      explicit: (c.width !== undefined && c.height !== undefined) ? { width: c.width, height: c.height } : undefined,
      caption: c.caption,
    }))}
  /></div>
)}

{b.type === 'mermaid' && mermaidSvg !== null && (
  <figure class="dia">
    <div class="dia-body" set:html={mermaidSvg} />
    <figcaption><span class="dia-label">DIAGRAM</span>{b.question}</figcaption>
  </figure>
)}

{b.type === 'api-list' && (
  <ApiList margin="14px 0" sigWidth={230} firstHeadPadBottom={4} groups={b.groups} />
)}

{b.type === 'callout' && (
  <Callout badge={b.badge} tone={b.tone} title={b.title} body={b.body} padding="15px 17px" margin="18px 0 0" />
)}

{b.type === 'chips' && b.variant === 'loop' && (
  <LoopChips margin="14px 0" steps={b.items} />
)}
{b.type === 'chips' && b.variant === 'flow' && (
  <FlowChips margin="14px 0" steps={b.items.map((it: any) => it.label)} />
)}
{b.type === 'chips' && b.variant === 'condition' && (
  <ConditionPills marginBottom="6px" items={b.items.map((it: any) => it.label)} />
)}
{/* 스키마는 알약 색을 tone 으로 받고 StateChips 는 kind 로 읽는다 — 어댑터에서 잇는다. */}
{b.type === 'chips' && (b.variant === undefined || b.variant === 'state') && (
  <StateChips steps={b.items.map((it: any) => ({ label: it.label, kind: it.tone, arrow: it.arrow }))} tail={b.tail} />
)}

<style>
  .scroll { overflow-x: auto; }

  .prose { display: grid; gap: 12px; margin: 4px 0; }
  .prose p { font-size: 14.5px; line-height: 1.75; color: var(--ink-soft); }

  /* 코드 아래 '왜' 주석 — 디자인 Code 엔 없는, YAML 이 더 가진 내용이다. */
  .code-wrap { display: grid; gap: 10px; }
  .notes { display: grid; gap: 6px; margin: 2px 0 4px; }
  .notes li { display: grid; grid-template-columns: minmax(96px, auto) 1fr; gap: 12px; font-size: 12.5px; line-height: 1.6; }
  .notes .at { font: 700 11.5px var(--mono); color: var(--accent); }
  .notes .why { color: var(--ink-soft); }

  /* 계층도 위 구성·관계·흐름. 가이드 ②: 그림만 있으면 독자가 해석하지 못한다. */
  .layers-wrap { margin: 6px 0; }
  .triplet { display: grid; gap: 9px; margin-bottom: 4px; }
  .triplet > div { display: grid; grid-template-columns: 66px 1fr; gap: 12px; }
  .triplet dt {
    font: 600 9.5px var(--mono); letter-spacing: .1em; color: #fff;
    background: var(--accent); border-radius: 5px; padding: 3px 0; text-align: center; height: fit-content;
  }
  .triplet dd { font-size: 13px; line-height: 1.68; color: var(--ink-soft); }

  /* Mermaid 다이어그램 */
  .dia { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; margin: 16px 0; }
  .dia-body { overflow-x: auto; padding: 20px 18px; }
  .dia-body :global(svg) { max-width: 100%; height: auto; display: block; margin: 0 auto; }
  .dia figcaption {
    display: flex; align-items: baseline; gap: 10px; padding: 10px 14px 12px;
    border-top: 1px solid var(--line); font-size: 12px; line-height: 1.6; color: var(--ink-faint);
  }
  .dia-label { flex: none; font: 700 8.5px var(--mono); letter-spacing: .14em; color: #fff; background: var(--accent); border-radius: 4px; padding: 3px 6px; }
</style>
